_credit_for_label_hi": "", "headline_credit_for_label": "<p>AU, 1966</p>", "headline_credit_for_label_zh_hans": "", "headline_credit_for_label_pa": "", "headline_credit_for_label_hi": "", "title_for_label_zh_hans": "", "title_for_label_pa": "", "title_for_label_hi": "", "title_for_label_override_zh_hans": "", "title_for_label_override_pa": "", "title_for_label_override_hi": "", "description_for_label_zh_hans": "", "description_for_label_pa": "", "description_for_label_hi": "", "description_for_label_override_zh_hans": "", "description_for_label_override_pa": "", "description_for_label_override_hi": "", "description_zh_hans": "", "description_pa": "", "description_hi": "", "description_override_zh_hans": "", "description_override_pa": "", "description_override_hi": ""}, "description": "<p>ABC&#8217;s <i>Play School</i> has always featured a clock, with the original rocket and flower clocks assuming iconic status and their removal represented the end of an era. Subsequent clocks have now become symbolic of transience.</p>"}], "published": true, "shape": null}