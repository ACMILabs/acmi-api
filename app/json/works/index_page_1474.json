false, "external_references": []}, {"id": 99480, "acmi_id": "E000221", "title": "Std 8 & 16mm cement splicer", "title_annotation": "", "slug": "wat-vic-splicer-for-8mm-16mm-movie-film", "creator_credit": "Wat Vic", "credit_line": "<p>ACMI Collection</p>", "headline_credit": "Japan, c. 1950s", "video_links": [], "record_type": "work", "type": "Object", "is_on_display": true, "last_on_display_place": "ACMI: Gallery 1", "last_on_display_date": "2031-02-16", "is_context_indigenous": false, "material_description": "", "unpublished": false, "external": false, "first_production_date": null, "commissioned": false, "public_domain": false, "external_references": []}, {"id": 99493, "acmi_id": "E000222", "title": "Std 8 & 16mm cement splicer", "title_annotation": "", "slug": "eumig-film-splicer", "creator_credit": "Eumig", "credit_line": "<p>ACMI Collection</p>", "headline_credit": "Japan, c. 1960s", "video_links": [], "record_type": "work", "type": "Object", "is_on_display": true, "last_on_display_place": "ACMI: Gallery 1", "last_on_display_date": "2031-02-16", "is_context_indigenous": false, "material_description": "", "unpublished": false, "external": false, "first_production_date": null, "commissioned": false, "public_domain": false, "external_references": []}], "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "179399", "eaas_environment_id": null, "production_places": [{"id": 10, "name": "United Kingdom", "slug": "united-kingdom"}], "production_dates": [], "labels": [39055]}, {"id": 99492, "acmi_id": "E000245", "title": "M.2-16mm 2T splicer", "title_annotation": "", "slug": "catozzo-m2-16mm-2t-splicer", "creator_credit": "Catozzo and C.I.R. srl", "credit_line": "<p>ACMI Collection</p>", "headline_credit": "Italy, c. 1980s", "video_links": [], "record_type": "work", "type": "Object", "is_on_display": true, "last_on_display_place": "ACMI: Gallery 1", "last_on_display_date": "2031-02-16", "is_context_indigenous": false, "material_description": "", "unpublished": false, "external": false, "first_production_date": null, "commissioned": false, "public_domain": false, "external_references": [], "brief_description": "<p>The splicer, afterwards simply know as the &#8220;Catozzo&#8221;, was born as a result of a serious form of allergy to the smell of the cement suffered by his inventor which produced the happy intuition to use adhesive tape in its place, for joining the various film ends together.<br />\nThis idea was subsequently consolidated and patented all over the world, developing into all the various currently existing models. [SOURCE: https://www.cir-srl.com/ last accessed 20/06/2019]</p>\n<p>CIR (Costruzione Incollatrici Rapide) Catozzo</p>\n<p>Incollatrice M. 2-16mm 2T splicer<br />\nwith adhesive tape<br />\nhoused in original cardbox box.</p>\n<p>Housed in storage box stamped three times with:<br />\nMichael Hudson<br />\nPhone  387 4549<br />\nFilm Production &amp; design<br />\n626 Park Street<br />\nNorth Carlton   VIC   3054</p>\n<p>Included are: Instructions per film 16mm<br />\ndescription of splicers flier that folds out.<br />\nMade in Italy.  Patented</p>\n<p>Label at the bottom of the splicer has been attached which says:<br />\nMichael Hudson<br />\nPhone  387 4549<br />\nFilm Production &amp; design<br />\n626 Park Street<br />\nNorth Carlton   VIC   3054</p>\n<p>Inscribed at the base:  Made in Italy.  US pat</p>\n<p>silver label at the base reads:<br />\nmade in Italy by<br />\nOfficine Meccaniche<br />\nDr. Leo Catozzo<br />\n00050 Santa Severa (Roma)<br />\nTel. 0766/78008-78181</p>\n<p>FPB A-2025</p>", "constellations_primary": [], "constellations_other": [], "recommendations": [], "creator_credit_for_label": "<p>Catozzo and C.I.R. srl</p>", "headline_credit_for_label": "<p>Italy, c. 1980s</p>", "title_for_label": "<p>M.2-16mm 2T splicer</p>", "description": "<p>The splicer, afterwards simply know as the &#8220;Catozzo&#8221;, was born as a result of a serious form of allergy to the smell of the cement suffered by his inventor which produced the happy intuition to use adhesive tape in its place, for joining the various film ends together.<br />\nThis idea was subsequently consolidated and patented all over the world, developing into all the various currently existing models. [SOURCE: https://www.cir-srl.com/ last accessed 20/06/2019]</p>\n<p>CIR (Costruzione Incollatrici Rapide) Catozzo</p>\n<p>Incollatrice M. 2-16mm 2T splicer<br />\nwith adhesive tape<br />\nhoused in original cardbox box.</p>\n<p>Housed in storage box stamped three times with:<br />\nMichael Hudson<br />\nPhone  387 4549<br />\nFilm Production &amp; design<br />\n626 Park Street<br />\nNorth Carlton   VIC   3054</p>\n<p>Included are: Instructions per film 16mm<br />\ndescription of splicers flier that folds out.<br />\nMade in Italy.  Patented</p>\n<p>Label at the bottom of the splicer has been attached which says:<br />\nMichael Hudson<br />\nPhone  387 4549<br />\nFilm Production &amp; design<br />\n626 Park Street<br />\nNorth Carlton   VIC   3054</p>\n<p>Inscribed at the base:  Made in Italy.  US pat</p>\n<p>silver label at the base reads:<br />\nmade in Italy by<br />\nOfficine Meccaniche<br />\nDr. Leo Catozzo<br />\n00050 Santa Severa (Roma)<br />\nTel. 0766/78008-78181</p>\n<p>FPB A-2025</p>", "description_for_label": ["<p>The splicer, afterwards simply know as the &#8220;Catozzo&#8221;, was born as a result of a serious form of allergy to the smell of the cement suffered by his inventor which produced the happy intuition to use adhesive tape in its place, for joining the various film ends together.<br />\nThis idea was subsequently consolidated and patented all over the world, developing into all the various currently existing models. [SOURCE: https://www.cir-srl.com/ last accessed 20/06/2019]</p>\n<p>CIR (Costruzione Incollatrici Rapide) Catozzo</p>\n<p>Incollatrice M. 2-16mm 2T splicer<br />\nwith adhesive tape<br />\nhoused in original cardbox box.</p>\n<p>Housed in storage 