: "xos-60859", "title": "The Blind Man of Siloam", "title_zh_hans": "", "title_pa": "", "title_hi": "", "title_annotation": "", "title_annotation_zh_hans": "", "title_annotation_pa": "", "title_annotation_hi": "", "slug": "the-blind-man-of-siloam", "creator_credit": "", "credit_line": "", "credit_line_zh_hans": "", "credit_line_pa": "", "credit_line_hi": "", "headline_credit": "", "video_links": [], "record_type": "work", "type": "Object", "is_on_display": false, "last_on_display_place": null, "last_on_display_date": null, "is_context_indigenous": false, "material_description": "", "unpublished": false, "external": false, "first_production_date": null, "commissioned": false, "public_domain": false, "external_references": [], "brief_description": "<p>The Salvation Army isn’t just part of Melbourne’s social fabric, it&#8217;s also an integral part of moving image history. The Salvation Army ran Australia’s first production company, The Limelight Department, from 1897 to 1910. Here they produced hundreds of scenes and stories by photographing actors with elaborate sets and costumes, printing them on slides and then hand-colouring them in the department’s Bourke Street studio. The Blind Man of Siloam shows how this technique recreated ancient locations from hand-painted backgrounds. The department’s most famous show, Soldiers of the Cross, featured over 200 slides projected from multiple lanterns as well as hymns, music, motion picture segments and rousing narration.</p>", "constellations_primary": [], "constellations_other": [], "recommendations": [], "creator_credit_for_label": "", "creator_credit_for_label_zh_hans": "", "creator_credit_for_label_pa": "", "creator_credit_for_label_hi": "", "headline_credit_for_label": "", "headline_credit_for_label_zh_hans": "", "headline_credit_for_label_pa": "", "headline_credit_for_label_hi": "", "title_for_label_zh_hans": "", "title_for_label_pa": "", "title_for_label_hi": "", "title_for_label_override_zh_hans": "", "title_for_lab