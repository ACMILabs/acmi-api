27", "title": "Spotlights: Tony Ayres", "title_annotation": "", "slug": "spotlights-tony-ayres", "creator_credit": "", "credit_line": "", "headline_credit": "Australia, 2020", "video_links": [], "record_type": "work", "type": "Film", "is_on_display": true, "last_on_display_place": "ACMI: Gallery 1", "last_on_display_date": "2031-02-16", "is_context_indigenous": false, "material_description": "", "unpublished": false, "external": false, "first_production_date": "2020-01-01T11:00:00+11:00", "commissioned": true, "public_domain": false, "external_references": []}, {"id": 117910, "acmi_id": "B2004325", "title": "Spotlights: Warwick Thornton", "title_annotation": "", "slug": "spotlights-warwick-thornton", "creator_credit": "", "credit_line": "", "headline_credit": "Australia, 2020", "video_links": [], "record_type": "work", "type": "Film", "is_on_display": true, "last_on_display_place": "ACMI: Gallery 1", "last_on_display_date": "2031-02-16", "is_context_indigenous": false, "material_description": "", "unpublished": false, "external": false, "first_production_date": "2020-01-01T11:00:00+11:00", "commissioned": true, "public_domain": false, "external_references": []}], "group_siblings": [], "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "183979", "eaas_environment_id": null, "production_places": [{"id": 3, "name": "Australia", "slug": "australia"}], "production_dates": [{"date": "2020", "notes": "created for ACMI's renewal opening 2021", "to_year": "2020"}], "labels": [59791]}, {"id": 117910, "acmi_id": "B2004325", "title": "Spotlights: Warwick Thornton", "title_annotation": "", "slug": "spotlights-warwick-thornton", "creator_credit": "", "credit_line": "", "headline_credit": "Australia, 2020", "video_links": [], "record_type": "work", "type": "Film", "is_on_display": true, "last_on_display_place": "ACMI: Gallery 1", "last_on_display_date": "2031-02-16", "is_context_indigenous": false, "material_description": "", "unpublished": false, "external": false, "first_production_date": "2020-01-01T11:00:00+11:00", "commissioned": true, "public_domain": false, "external_references": [], "brief_description": "<p>A Kaytetye man born and raised in Alice Springs. A film director, screenwriter and cinematographer, his debut feature film Samson and Delilah won the Caméra d&#8217;Or at the 2009 Cannes Film Festival. He also won the Asia Pacific Screen Award for Best Film in 2017 for Sweet Country.</p>", "constellations_primary": [{"id": 268, "name": "Warwick Thornton", "description": "Brimming with Shakespearean undertones and pathos, Kaytetye filmmaker Warwick Thornton's debut feature <i>Samson and Delilah</i> is both a universal tale and one intrinsically tied to the experience of First Peoples in Central Australia."}], "constellations_other": [], "recommendations": [], "title_for_label": "<p>Warwick Thornton</p>", "creator_credit_for_label": "", "headline_credit_for_label": "<p>Filmmaker</p>", "description": "<p>Warwick Thornton is a Kaytetye man born and raised in Alice Springs. A film director, screenwriter and cinematographer, his debut feature film <i>Samson and Delilah</i> won the Caméra d&#8217;Or at the 2009 Cannes Film Festival. He also won the Asia Pacific Screen Award for Best Film in 2017 for <i>Sweet Country</i>.</p>", "description_for_label": ["<p>Warwick Thornton is a Kaytetye man born and raised in Alice Springs. A film director, screenwriter and cinematographer, his debut feature film <i>Samson and Delilah</i> won the Caméra d&#8217;Or at the 2009 Cannes Film Festival. He also won the Asia Pacific Screen Award for Best Film in 2017 for <i>Sweet Country</i>.</p>"], "credit_line_for_label": "", "details": [{"label": "Language", "display_values": ["English"]}, {"label": "Subject categories", "display_values": ["Archival, Cinemagazines & Newsreels&nbsp;→ Interviews", "Short films", "Short films&nbsp;→ Short films - Australia"]}, {"label": "Curatorial section", "display_values": ["The Story of the Moving Image&nb