{"count": 41745, "next": "https://api.acmi.net.au/works/?page=3070", "previous": "https://api.acmi.net.au/works/?page=3068", "results": [{"id": 100599, "acmi_id": "P180320", "title": "Alice Guy-Blaché", "title_zh_hans": "", "title_pa": "", "title_hi": "", "title_annotation": "Facsimile", "title_annotation_zh_hans": "", "title_annotation_pa": "", "title_annotation_hi": "", "slug": "alice-guy-blache", "creator_credit": "", "credit_line": "<p>Courtesy Everett Collection Inc / Alamy</p>", "credit_line_zh_hans": "", "credit_line_pa": "", "credit_line_hi": "", "headline_credit": "France, c. 1900", "video_links": [], "record_type": "work", "type": "Object", "is_on_display": true, "last_on_display_place": "ACMI: Gallery 1", "last_on_display_date": "2031-02-16", "is_context_indigenous": false, "material_description": "graphic", "unpublished": false, "external": false, "first_production_date": null, "commissioned": false, "public_domain": false, "external_references": [], "brief_description": "<p>Alice Guy-Blaché was a trailblazing French director, producer and screenwriter, and the co-founder and artistic director of her own film studio. She made hundreds of films between during her career, including the first fictional film with a scripted narrative, La Fée aux Choux</p>", "constellations_primary": [{"id": 48, "name": "Lost and found", "description": "Blossoming from Alice Guy Blaché’s <i>The Cabbage-Patch Fairy</i>, this Constellation explores the impermanence and enduring nature of the moving image."}], "constellations_other": [], "recommendations": [], "creator_credit_for_label": "", "creator_credit_for_label_zh_hans": "", "creator_credit_for_label_pa": "", "creator_credit_for_label_hi": "", "headline_credit_for_label": "<p>France, c. 1900</p>", "headline_credit_for_label_zh_hans": "", "headline_credit_for_label_pa": "", "headline_credit_for_label_hi": "", "title_for_label_zh_hans": "", "title_for_label_pa": "", "title_for_label_hi": "", "title_for_label_override_zh_hans": "", "title_for_label_override_pa": "", "title_for_label_override_hi": "", "description_for_label_zh_hans": "", "description_for_label_pa": "", "description_for_label_hi": "", "description_for_label_override_zh_hans": "", "description_for_label_override_pa": "", "description_for_label_override_hi": "", "description_zh_hans": "", "description_pa": "", "description_hi": "", "description_override_zh_hans": "", "description_override_pa": "", "description_override_hi": "", "title_for_label": "<p>Alice Guy-Blaché</p>", "description": "<p>Alice Guy-Blaché was a trailblazing French director, producer and screenwriter, and the co-founder and artistic director of her own film studio, Solax. She made hundreds of films between 1896 and the 1920s, including the first fictional film with a scripted narrative, <i>La Fée aux Choux</i> (<i>The Cabbage Fairy</i>, 1896).</p>\n<p>Guy-Blaché later experimented with early synchronised sound, colour and special effects, often filming on location with hundreds of extras. In 1912 she made <i>A Fool and His Money</i>, widely believed to be the first film to have an all–African American cast.</p>\n<p><b>To find our more about Alice Guy-Blaché, <a href=\"https://cinema3.acmi.net.au/film/be-natural-the-untold-story-of-alice-guy-blache/\">rent <I>Be Natural: The Untold Story of Alice Guy-Blaché</i> on our streaming platform, Cinema 3</a>.</b></p>", "description_for_label": ["<p>Alice Guy-Blaché was a trailblazing French director, producer and screenwriter, and the co-founder and artistic director of her own film studio, Solax. She made hundreds of films between 1896 and the 1920s, including the first fictional film with a scripted narrative, <i>La Fée aux Choux</i> (<i>The Cabbage Fairy</i>, 1896).</p>\n<p>Guy-Blaché later experimented with early synchronised sound, colour and special effects, often filming on location with hundreds of extras. In 1912 she made <i>A Fool and His Money</i>, widely believed to be the first film to have an all–African American cast.</p>"], "credit_line_for_label": "<p>Courtesy Everett Collection Inc / Alamy</p>", "details": [{"label": "Curatorial section", "display_values": ["The Story of the Moving Image&nbsp;→ Moving Pictures&nbsp;→ MI-04. Materiality&nbsp;→ MI-04-C01"]}, {"label": "Object Types", "display_values": ["2D Object", "Exhibition Prop", "Photographic print/Pictorial"]}, {"label": "Materials", "display_values": ["graphic"]}], "stats": {"tap_count": 2562}, "links": [], "creators_primary": [], "creators_other": [], "media_note": null, "holdings": [], "part_of": null, "parts": [], "part_siblings": [], "group": null, "group_works": [], "group_siblings": [], "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "180320", "eaas_environment_id": null, "production_places": [{"id": 17, "name": "France", "slug": "france"}], "production_dates": [{"date": "c. 1900", "notes": "", "to_year": "c. 1900"}], "labels": [40093], "title_override_zh_hans": "", "title_override_pa": "", "title_override_hi": "", "credit_line_for_label_zh_hans": "", "credit_line_for_label_pa": "", "credit_line_for_label_hi": "", "credit_line_for_label_override_zh_hans": "", "credit_line_for_label_override_pa": "", "credit_line_for_label_override_hi": "", "credit_line_override_zh_hans": "", "credit_line_override_pa": "", "credit_line_override_hi": ""}, {"id": 117672, "acmi_id": "509997", "title": "Meanings are in people", "title_zh_hans": "", "title_pa": "", "title_hi": "", "title_annotation": "", "title_annotation_zh_hans": "", "title_annotation_pa": "", "title_annotation_hi": "", "slug": "meanings-are-in-people", "creator_credit": "", "credit_line": "", "credit_line_zh_hans": "", "credit_line_pa": "", "credit_line_hi": "", "headline_credit": "United States, 1965", "video_links": [], "record_type": "work", "type": "Film", "is_on_display": false, "last_on_display_place": null, "last_on_display_date": null, "is_context_indigenous": false, "material_description": "", "unpublished": false, "ext