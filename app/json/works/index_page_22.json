n_display_date": null, "is_context_indigenous": false, "material_description": "Single channel moving image", "unpublished": false, "external": false, "first_production_date": "1987-01-01T11:00:00+11:00", "commissioned": false, "public_domain": false, "external_references": [], "brief_description": "<p>In this video diary style film, Kuchar lets go of his usual comic persona to explore “the depression inherent to festive occasions.” From Thanksgiving dinner with friends, to a student film night disrupted by a riot, to a solemn conversation with a lover. Kuchar demonstrates the melancholy that accompanies his day-to-day routine in the rainy California holiday season.</p>", "constellations_primary": [], "constellations_other": [], "recommendations": [], "creator_credit_for_label": "<p>George Kuchar</p>", "headline_credit_for_label": "<p>United States, 1987</p>", "title_for_label": "<p>Rainy season</p>", "description": "<p>In this video diary style film, Kuchar lets go of his usual comic persona to explore “the depression inherent to festive occasions.” From Thanksgiving dinner with friends, to a student film night disrupted by a riot, to a solemn conversation with a lover. Kuchar demonstrates the melancholy that accompanies his day-to-day routine in the rainy California holiday season.</p>", "description_for_label": ["<p>In this video diary style film, Kuchar lets go of his usual comic persona to explore “the depression inherent to festive occasions.” From Thanksgiving dinner with friends, to a student film night disrupted by a riot, to a solemn conversation with a lover. Kuchar demonstrates the melancholy that accompanies his day-to-day routine in the rainy California holiday season.</p>"], "credit_line_for_label": "", "details": [{"label": "Duration", "display_values": ["00:28:00:00"]}, {"label": "Language", "display_values": ["English"]}, {"label": "Audience classification", "display_values": ["unclassified"]}, {"label": "Subject categories", "display_values": ["Di