ralia, 2020", "video_links": [], "record_type": "work", "type": "Film", "is_on_display": true, "last_on_display_place": "ACMI: Gallery 1", "last_on_display_date": "2031-02-16", "is_context_indigenous": false, "material_description": "", "unpublished": false, "external": false, "first_production_date": "2020-01-01T11:00:00+11:00", "commissioned": true, "public_domain": false, "external_references": [], "brief_description": "<p>An Australian film editor, a member of the Australian Screen Editors guild, as well as the American Cinema Editors society, who has edited films such as Romeo + Juliet (1996), Moulin Rouge! (2001) and Road to Perdition (2002).</p>", "constellations_primary": [{"id": 269, "name": "Jill Bilcock", "description": "An editor’s work often goes unnoticed, but their scene-stitching not only brings the director’s vision to life but sometimes steals the show. One of Australia’s greatest editors, Jill Bilcock, has shaped some of the country’s most memorable screen stories."}], "constellations_other": [{"id": 266, "name": "Ana Kokkinos", "description": "The films and TV works of Ana Kokkinos often explore the experiences of second-generation Australians, queer identities and class. Since beginning her career in the early 90s, those stories have started to appear more frequently on Australian screens."}], "recommendations": [], "creator_credit_for_label": "", "headline_credit_for_label": "<p>Film editor</p>", "title_for_label": "<p>Jill Bilcock</p>", "description": "<p>Jill Bilcock is an Australian film editor, a member of the Australian Screen Editors guild, as well as the American Cinema Editors society, who has edited films such as <i>Romeo + Juliet</i> (1996), <i>Moulin Rouge!</i> (2001) and <i>Road to Perdition</i> (2002). Jill discusses the editing process and the physicality of rushes, now lost in the digital age.</p>", "description_for_label": ["<p>Jill Bilcock is an Australian film editor, a member of the Australian Screen Editors guild, as well as the American Cinema Editors society, who has edited films such as <i>Romeo + Juliet</i> (1996), <i>Moulin Rouge!</i> (2001) and <i>Road to Perdition</i> (2002). Jill discusses the editing process and the physicality of rushes, now lost in the digital age.</p>"], "credit_line_for_label": "", "details": [{"label": "Language", "display_values": ["English"]}, {"label": "Subject categories", "display_values": ["Archival, Cinemagazines & Newsreels&nbsp;→ Interviews", "Short films", "Short films&nbsp;→ Short films - Australia"]}, {"label": "Curatorial section", "display_values": ["The Story of the Moving Image&nbsp;→ Moving Australia&nbsp;→ MA-09. Spotlights"]}, {"label": "Sound/audio", "display_values": ["Sound"]}, {"label": "Colour", "display_values": ["Black and White"]}, {"label": "Object Types", "display_values": ["Moving image file/Digital"]}], "stats": {"tap_count": 41143}, "links": [], "creators_primary": [], "creators_other": [], "media_note": null, "holdings": [], "part_of": null, "parts": [], "part_siblings": [], "group": {"id": 120326, "acmi_id": "B2004322", "title": "Spotlights", "title_annotation": "", "slug": "spotlights", "creator_credit": "Rolf De Heer and Tess Hall", "credit_line": "", "headline_credit": "Australia, 2020", "video_links": [], "record_type": "group", "type": "Film", "is_on_display": false, "last_on_display_place": null, "last_on_display_date": null, "is_context_indigenous": false, "material_description": "", "unpublished": false, "external": false, "first_production_date": "2020-01-01T11:00:00+11:00", "commissioned": true, "public_domain": false, "external_references": []}, "group_works": [], "group_siblings": [{"id": 117871, "acmi_id": "B2004323", "title": "Spotlights: Ana Kokkinos", "title_annotation": "", "slug": "interview-with-ana-kokkinos", "creator_credit": "", "credit_line": "", "headline_credit": "Australia, 2020", "video_links": [], "record_type": "work", "type": "Film", "is_on_display": true, "last_on_display_place": "ACMI: Gall