onment_id": null, "production_places": [{"id": 6, "name": "Indonesia", "slug": "indonesia"}], "production_dates": [{"date": "2019", "notes": "", "to_year": "2019"}], "labels": [38990]}, {"id": 100549, "acmi_id": "P179439", "title": "Custom MAME arcade machine ", "title_annotation": "", "slug": "arcade-mame-cabinet-street-fighter-2", "creator_credit": "Arcade Classics", "credit_line": "", "headline_credit": "Australia, 2017", "video_links": [], "record_type": "work", "type": "Videogame", "is_on_display": true, "last_on_display_place": "ACMI: Gallery 1", "last_on_display_date": "2031-02-16", "is_context_indigenous": false, "material_description": "", "unpublished": false, "external": false, "first_production_date": "2017-01-01T11:00:00+11:00", "commissioned": false, "public_domain": false, "external_references": [], "brief_description": "<p>One way to preserve videogames is emulation, which recreates retro hardware and software on modern machines. MAME (Multiple Arcade Machine Emulator) is one of the most important emulation tools.</p>", "constellations_primary": [], "constellations_other": [], "recommendations": [], "creator_credit_for_label": "<p>Arcade Classics</p>", "headline_credit_for_label": "<p>Australia, 2017</p>", "title_for_label": "<p>Custom MAME arcade machine </p>", "description": "<p>It’s not that easy to keep videogames running. Technology evolves at a rapid pace, including software and hardware, making some of the most iconic games from the past unplayable on today’s technology. Not to mention all the parts and programs used in videogames that are long obsolete and no longer supported. In the past fifty years, countless games have been lost.</p>\n<p>But it’s not all bad. One of the most important tools to preserve videogames is emulation, which recreates the hardware and software needed to run games on modern machines.</p>\n<p>MAME, or Multiple Arcade Machine Emulator, is one of the most well-known and important emulation tools. It recreates the inner workings of thousands of arcade machines, letting players in the present a chance to play the best games of the past.</p>", "description_for_label": ["<p>It’s not that easy to keep videogames running. Technology evolves at a rapid pace, including software and hardware, making some of the most iconic games from the past unplayable on today’s technology. Not to mention all the parts and programs used in videogames that are long obsolete and no longer supported. In the past fifty years, countless games have been lost.</p>\n<p>But it’s not all bad. One of the most important tools to preserve videogames is emulation, which recreates the hardware and software needed to run games on modern machines.</p>\n<p>MAME, or Multiple Arcade Machine Emulator, is one of the most well-known and important emulation tools. It recreates the inner workings of thousands of arcade machines, letting players in the present a chance to play the best games of the past.</p>"], "credit_line_for_label": "", "details": [{"label": "Curatorial section", "display_values": ["The Story of the Moving Image&nbsp;→ Games Lab&nbsp;→ GL-02. Cluster 2&nbsp;→ GL-02-C02"]}, {"label": "Measurements", "display_values": [""]}, {"label": "Object Types", "display_values": ["3D Object", "Computer game equipment/Game", "Exhibition Prop"]}], "stats": {"tap_count": 0}, "links": [], "creators_primary": [{"id": 2686354, "name": "Arcade Classics", "creator_id": 84339, "creator_wikidata_id": null, "role": "creator", "role_id": 968, "is_primary": true}], "creators_other": [], "media_note": "Sorry, we don't have images or video for this item.", "holdings": [], "part_of": null, "parts": [], "part_siblings": [], "group": {"id": 117937, "acmi_id": "", "title": "Retro gaming", "title_annotation": "", "slug": "retro-gaming", "creator_credit": "", "credit_line": "", "headline_credit": "", "video_links": [], "record_type": "group", "type": "Object", "is_on_display": true, "last_on_display_place": "ACMI: Gallery 1", "last_on_display