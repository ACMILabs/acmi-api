d": null, "production_places": [{"id": 18, "name": "Germany", "slug": "germany"}], "production_dates": [{"date": "1994", "notes": "", "to_year": "1994"}], "labels": [47835], "title_override_zh_hans": "", "title_override_pa": "", "title_override_hi": "", "credit_line_for_label_zh_hans": "", "credit_line_for_label_pa": "", "credit_line_for_label_hi": "", "credit_line_for_label_override_zh_hans": "", "credit_line_for_label_override_pa": "", "credit_line_for_label_override_hi": "", "credit_line_override_zh_hans": "", "credit_line_override_pa": "", "credit_line_override_hi": ""}, {"id": 108336, "acmi_id": "B1002336", "title": "The Land of nothing", "title_zh_hans": "", "title_pa": "", "title_hi": "", "title_annotation": "", "title_annotation_zh_hans": "", "title_annotation_pa": "", "title_annotation_hi": "", "slug": "the-land-of-nothing", "creator_credit": "Peter Forgacs", "credit_line": "", "credit_line_zh_hans": "", "credit_line_pa": "", "credit_line_hi": "", "headline_credit": "Hungary, 1996", "video_links": [], "record_type": "work", "type": "Film", "is_on_display": false, "last_on_display_place": null, "last_on_display_date": null, "is_context_indigenous": false, "material_description": "", "unpublished": false, "external": false, "first_production_date": "1996-01-01T11:00:00+11:00", "commissioned": false, "public_domain": false, "external_references": [], "brief_description": "<p>Life seemed almost normal in the nineteen thirties but Hungary had to pay the price for being an ally to the 3rd Reich. From 1938 to 1942 Laszlo Ratz - ensign of the Second Hungarian Army, first battalion of the 18th Szekszard infantry - documented his family on 9.5 mm within this toubled milieu. Through Peter Forgacs&#8217; recontextualisation of Ratz&#8217; material we are now permitted to gaze upon the unseen, the private view of a bloody war. By recording his personal history without an &#8216;ideological filter&#8217;, Ratz captured historical moments such as the Ukranian march and the final approach to the bloody Korotoyak/Voronezh Soviet front. Ratz shot until the eve of the catastrophe that befell the Hungarian Army at the river Don. He brought the films back home on his Christmas leave, and so this unique chronicle survived, together with the poetic family pictures.</p>", "constellations_primary": [], "constellations_other": [], "recommendations": [], "creator_credit_for_label": "<p>Peter Forgacs</p>", "creator_credit_for_label_zh_hans": "", "creator_credit_for_label_pa": "", "creator_credit_for_label_hi": "", "headline_credit_for_label": "<p>Hungary, 1996</p>", "headline_credit_for_label_zh_hans": "", "headline_credit_for_label_pa": "", "headline_credit_for_label_hi": "", "title_for_label_zh_hans": "", "title_for_label_pa": "", "title_for_label_hi": "", "title_for_label_override_zh_hans": "", "title_for_label_override_pa": "", "title_for_label_override_hi": "", "description_for_label_zh_hans": "", "description_for_label_pa": "", "description_for_label_hi": "", "description_for_label_override_zh_hans": "", "description_for_label_override_pa": "", "description_for_label_override_hi": "", "description_zh_hans": "", "description_pa": "", "description_hi": "", "description_override_zh_hans": "", "description_override_pa": "", "description_override_hi": "", "title_for_label": "<p>The Land of nothing</p>", "description": "<p>Life seemed almost normal in the nineteen thirties but Hungary had to pay the price for being an ally to the 3rd Reich. From 1938 to 1942 Laszlo Ratz - ensign of the Second Hungarian Army, first battalion of the 18th Szekszard infantry - documented his family on 9.5 mm within this toubled milieu. Through Peter Forgacs&#8217; recontextualisation of Ratz&#8217; material we are now permitted to gaze upon the unseen, the private view of a bloody war. By recording his personal history without an &#8216;ideological filter&#8217;, Ratz captured historical moments such as the Ukranian march and the final approach to the bloody Korotoyak/Voronezh Soviet front. Ratz shot until the eve of the catastrophe that befell the Hungarian Army at the river Don. He brought the films back home on his Christmas leave, and so this unique chronicle survived, together with the poetic family pictures.</p>", "description_for_label": ["<p>Life seemed almost normal in the nineteen thirties but Hungary had to pay the price for being an ally to the 3rd Reich. From 1938 to 1942 Laszlo Ratz - ensign of the Second Hungarian Army, first battalion of the 18th Szekszard infantry - documented his family on 9.5 mm within this toubled milieu. Through Peter Forgacs&#8217; recontextualisation of Ratz&#8217; material we are now permitted to gaze upon the unseen, the private view of a bloody war. By recording his personal history without an &#8216;ideological filter&#8217;, Ratz captured historical moments such as the Ukranian march and the final approach to the bloody Korotoyak/Voronezh Soviet front. Ratz shot until the eve of the catastrophe that befell the Hungarian Army at the river Don. He brought the films back home on his Christmas leave, and so this unique chronicle survived, together with the poetic family pictures.</p>"], "credit_line_for_label": "", "details": [{"label": "Languages", "display_values": ["English", "Hungarian"]}, {"label": "Subject category", "display_values": ["Foreign language films"]}], "stats": {"tap_count": 0}, "links": [], "creators_primary": [{"id": 2619272, "name": "Peter Forgacs", "creator_id": 6357, "creator_wikidata_id": null, "role": "creator", "role_id": 968, "is_primary": true}], "creators_other": [{"id": 2619273, "name": "Tibor Szemzö", "creator_id": 73087, "creator_wikidata_id": "Q4415411", "role": "composer", "role_id": 538, "is_primary": false}], "media_note": null, "holdings": [{"name": "Digital Betacam [PAL]; Master", "identifier": "", "description": ""}, {"name": "Digital Betacam [PAL]; Sub-master", "identifier": "", "description": ""}, {"name": "VHS [PAL]; Reference - timecoded", "ide