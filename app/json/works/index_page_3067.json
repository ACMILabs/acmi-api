dings": [{"name": "VHS; Access Print (Section 1)", "identifier": "", "description": ""}], "part_of": null, "parts": [], "part_siblings": [], "group": null, "group_works": [], "group_siblings": [], "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "35817", "eaas_environment_id": null, "production_places": [{"id": 3, "name": "Australia", "slug": "australia"}], "production_dates": [{"date": "1965", "notes": "Produced", "to_year": "1965"}], "labels": [19484], "title_override_zh_hans": "", "title_override_pa": "", "title_override_hi": "", "credit_line_for_label_zh_hans": "", "credit_line_for_label_pa": "", "credit_line_for_label_hi": "", "credit_line_for_label_override_zh_hans": "", "credit_line_for_label_override_pa": "", "credit_line_for_label_override_hi": "", "credit_line_override_zh_hans": "", "credit_line_override_pa": "", "credit_line_override_hi": ""}, {"id": 99433, "acmi_id": "AEO175771", "title": "US Navy Ciné-Kodak Special", "title_zh_hans": "", "title_pa": "", "title_hi": "", "title_annotation": "", "title_annotation_zh_hans": "", "title_annotation_pa": "", "title_annotation_hi": "", "slug": "eastman-kodak-us-navy-cine-kodak-special-16mm-camera", "creator_credit": "Eastman Kodak", "credit_line": "", "credit_line_zh_hans": "", "credit_line_pa": "", "credit_line_hi": "", "headline_credit": "United States, c. 1940s", "video_links": [], "record_type": "work", "type": "Object", "is_on_display": true, "last_on_display_place": "ACMI: Gallery 1", "last_on_display_date": "2031-02-16", "is_context_indigenous": false, "material_description": "vintage movie camera", "unpublished": false, "external": false, "first_production_date": null, "commissioned": false, "public_domain": false, "external_references": [], "brief_description": "<p>Eastman Kodak introduced the Ciné-Kodak Special in 1933. The silent 16mm camera was durable and lightweight enough to be used by combat photographers working in the field and Kodak manufactured a military version in all-black without the usual chrome edges.</p>", "constellations_primary": [{"id": 173, "name": "Australia and WW2", "description": "A constellation exploring representations of Australians during World War 2."}], "constellations_other": [], "recommendations": [], "creator_credit_for_label": "<p>Eastman Kodak</p>", "creator_credit_for_label_zh_hans": "", "creator_credit_for_label_pa": "", "creator_credit_for_label_hi": "", "headline_credit_for_label": "<p>United States, c. 1940s</p>", "headline_credit_for_label_zh_hans": "", "headline_credit_for_label_pa": "", "headline_credit_for_label_hi": "", "title_for_label_zh_hans": "", "title_for_label_pa": "", "title_for_label_hi": "", "title_for_label_override_zh_hans": "", "title_for_label_override_pa": "", "title_for_label_override_hi": "", "description_for_label_zh_hans": "", "description_for_label_pa": "", "description_for_label_hi": "", "description_for_label_override_zh_hans": "", "description_for_label_override_pa": "", "description_for_label_override_hi": "", "description_zh_hans": "", "description_pa": "", "description_hi": "", "description_override_zh_hans": "", "description_override_pa": "", "description_override_hi": "", "title_for_label": "<p>US Navy Ciné-Kodak Special</p>", "description": "<p>Footage captured during war has the ability to give audiences a sense of what is happening in combat, documenting the frontlines with an unflinching lens and bearing witness to atrocities. Yet it can also be used as propaganda to enlist forces, making it a powerful tool. Eastman Kodak introduced the Ciné-Kodak Special in 1933 following on from its earlier model the Ciné-Kodak in 1923. The silent 16mm camera was durable and lightweight enough to be used by combat photographers working in the field and Kodak manufactured a military version in all-black without the usual chrome edges.</p>", "description_for_label": ["<p>Footage captured during war has the ability to give audiences a sense of what is happening in combat, documenting the frontlines with an unflinching lens and bearing witness to atrocities. Yet it can also be used as propaganda to enlist forces, making it a powerful tool. Eastman Kodak introduced the Ciné-Kodak Special in 1933 following on from its earlier model the Ciné-Kodak in 1923. The silent 16mm camera was durable and lightweight enough to be used by combat photographers working in the field and Kodak manufactured a military version in all-black without the usual chrome edges.</p>"], "credit_line_for_label": "", "details": [{"label": "Subject category", "display_values": ["object&nbsp;→ 3D artefact"]}, {"label": "Curatorial section", "display_values": ["The Story of the Moving Image&nbsp;→ Moving Minds&nbsp;→ MM-05. Camera Tech&nbsp;→ MM-05-C01"]}, {"label": "Measurements", "display_values": ["150 x 85 x 340mm"]}, {"label": "Object Types", "display_values": ["Camera/ Camera crane / Camera lens/Film and television equipment"]}, {"label": "Materials", "display_values": ["vintage movie camera"]}], "stats": {"tap_count": 8612}, "links": [], "creators_primary": [{"id": 1883720, "name": "Eastman Kodak", "creator_id": 10305, "creator_wikidata_id": null, "role": "manufacturer", "role_id": 627, "is_primary": true}], "creators_other": [], "media_note": null, "holdings": [], "part_of": null, "parts": [], "part_siblings": [], "group": null, "group_works": [], "group_siblings": [], "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "175771", "eaas_environment_id": null, "production_places": [{"id": 2, "name": "United States", "slug": "united-states"}], "production_dates": [{"date": "c. 1940s", "notes": "estimated", "to_year": "c. 1940s"}], "labels": [38928], "title_override_zh_hans": "", "title_override_pa": "", "title_override_hi": "", "credit_line_for_label_zh_hans": "", "credit_line_for_label_pa": "", "credit_line_for_label_hi": "", "credit_line_for_label_override_zh_hans": "", "credit_line_for_label_override_pa": "", "credit_line_for_label_override_hi": "", "cred