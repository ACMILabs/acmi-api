modore 64 holds a unique place in the history of video games. Institutions such as the National Museum of American History and the Science Museum London also hold Commodore 64 consoles in their collections to highlight the impact and significance the C64 had on computing and home video games.</p>", "description_for_label": ["<p>Commodore 64 Console without joysticks or power cords<br />\nSerial Number WGB 28483</p>"], "credit_line_for_label": "<p>ACMI Collection</p>", "details": [{"label": "Curatorial section", "display_values": ["The Story of the Moving Image&nbsp;→ Foyer&nbsp;→ Entry&nbsp;→ FSF-03. MPL exterior"]}, {"label": "Measurements", "display_values": ["83 x 405 x 206mm"]}, {"label": "Object Types", "display_values": ["3D Object", "Computer game equipment/Game"]}], "stats": {"tap_count": 1}, "links": [], "creators_primary": [{"id": 2686149, "name": "Commodore Business Machines", "creator_id": 73000, "creator_wikidata_id": null, "role": "manufacturer", "role_id": 627, "is_primary": true}], "creators_other": [], "media_note": null, "holdings": [], "part_of": null, "parts": [], "part_siblings": [], "group": {"id": 113855, "acmi_id": "", "title": "Commodore 64 console and cassettes", "title_annotation": "", "slug": "mpl-display-group-commodore-64-console-and-cassettes", "creator_credit": "Commodore Business Machines", "credit_line": "", "headline_credit": "1985", "video_links": [], "record_type": "group", "type": "Object", "is_on_display": true, "last_on_display_place": "ACMI: Gallery 1", "last_on_display_date": "2031-02-16", "is_context_indigenous": false, "material_description": "", "unpublished": false, "external": true, "first_production_date": "1985-01-01T11:00:00+11:00", "commissioned": false, "public_domain": false, "external_references": []}, "group_works": [], "group_siblings": [{"id": 99897, "acmi_id": "E000283", "title": "Commodore C2N Datasette", "title_annotation": "", "slug": "commodore-c2n-datasette", "creator_credit": "Commodore Business Machine