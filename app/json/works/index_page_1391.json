hilip Brophy", "credit_line": "", "credit_line_zh_hans": "", "credit_line_pa": "", "credit_line_hi": "", "headline_credit": "Australia, 2003", "video_links": [], "record_type": "work", "type": "Artwork", "is_on_display": false, "last_on_display_place": "ACMI Screen Gallery", "last_on_display_date": "2004-09-12", "is_context_indigenous": false, "material_description": "video, interactive software, mixed media, colour and sound", "unpublished": false, "external": false, "first_production_date": "2003-01-01T11:00:00+11:00", "commissioned": true, "public_domain": false, "external_references": [], "brief_description": "<p>The Body Malleable is an intimate interactive work where a custom built &#8216;gromit&#8217; is physically engaged with by the viewer to create a display combining digital animation and synchronised audio in the installation space. The custom interface, placed on a desk for one viewer to interact with at a time, is internally configured with a 100 key keyboard broken up and reassembled within the spherical space. Darkness within the pod, the viewer is asked to insert their finger into a small opening to probe the key board lining. The keys pressed act as switches to key events programmed into Director and thus set off a series of audio-visual responses via surround sound and a single circular screen projection to create an intimate experiential space determined by the audiences interaction.</p>", "constellations_primary": [], "constellations_other": [], "recommendations": [], "creator_credit_for_label": "<p>Philip Brophy</p>", "creator_credit_for_label_zh_hans": "", "creator_credit_for_label_pa": "", "creator_credit_for_label_hi": "", "headline_credit_for_label": "<p>Australia, 2003</p>", "headline_credit_for_label_zh_hans": "", "headline_credit_for_label_pa": "", "headline_credit_for_label_hi": "", "title_for_label_zh_hans": "", "title_for_label_pa": "", "title_for_label_hi": "", "title_for_label_override_zh_hans": "", "title_for_label_override_pa": ""