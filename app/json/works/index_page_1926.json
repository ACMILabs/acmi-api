l_pa": "", "creator_credit_for_label_hi": "", "headline_credit_for_label": "<p>United States</p>", "headline_credit_for_label_zh_hans": "", "headline_credit_for_label_pa": "", "headline_credit_for_label_hi": "", "title_for_label_zh_hans": "", "title_for_label_pa": "", "title_for_label_hi": "", "title_for_label_override_zh_hans": "", "title_for_label_override_pa": "", "title_for_label_override_hi": "", "description_for_label_zh_hans": "", "description_for_label_pa": "", "description_for_label_hi": "", "description_for_label_override_zh_hans": "", "description_for_label_override_pa": "", "description_for_label_override_hi": "", "description_zh_hans": "", "description_pa": "", "description_hi": "", "description_override_zh_hans": "", "description_override_pa": "", "description_override_hi": "", "title_for_label": "<p>16mm news camera with Cosmicar zoom lens used by GTV-9</p>", "description": "<p>Newsreel footage was captured on large, bulky 35mm cameras like the Mitchell Newsreel Camera by operators in the field. Three-legged tripods made from firm materials like steel and wood helped steady the kind of image that was collected in production vans for Cinesound Productions and Movietone News. Designed and manufactured in Los Angeles, this model was an improved design on the earlier Mitchell cameras, which were widely used by film production companies like those at Pagewood Studios in Sydney, Australia. The Mitchell Newsreel Camera was a quieter alternative, making it less invasive on sets and in the field.</p>", "description_for_label": ["<p>Newsreel footage was captured on large, bulky 35mm cameras like the Mitchell Newsreel Camera by operators in the field. Three-legged tripods made from firm materials like steel and wood helped steady the kind of image that was collected in production vans for Cinesound Productions and Movietone News. Designed and manufactured in Los Angeles, this model was an improved design on the earlier Mitchell cameras, which were widely used by film production companies like those at Pagewood Studios in Sydney, Australia. The Mitchell Newsreel Camera was a quieter alternative, making it less invasive on sets and in the field.</p>"], "credit_line_for_label": "<p>ACMI Collection</p>", "details": [{"label": "Curatorial section", "display_values": ["The Story of the Moving Image&nbsp;→ Moving Minds&nbsp;→ MM-05. Camera Tech&nbsp;→ MM-05-C01"]}, {"label": "Measurements", "display_values": ["145 x 65 x 65cm"]}, {"label": "Object Types", "display_values": ["3D Object", "Camera/ Camera crane / Camera lens/Film and television equipment"]}], "stats": {"tap_count": 72768}, "links": [], "creators_primary": [{"id": 2639018, "name": "Mitchell Camera Corporation", "creator_id": 82116, "creator_wikidata_id": null, "role": "manufacturer", "role_id": 627, "is_primary": true}], "creators_other": [], "media_note": null, "holdings": [], "part_of": null, "parts": [], "part_siblings": [], "group": null, "group_works": [], "group_siblings": [], "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "13269", "eaas_environment_id": null, "production_places": [{"id": 2, "name": "United States", "slug": "united-states"}], "production_dates": [], "labels": [39540], "title_override_zh_hans": "", "title_override_pa": "", "title_override_hi": "", "credit_line_for_label_zh_hans": "", "credit_line_for_label_pa": "", "credit_line_for_label_hi": "", "credit_line_for_label_override_zh_hans": "", "credit_line_for_label_override_pa": "", "credit_line_for_label_override_hi": "", "credit_line_override_zh_hans": "", "credit_line_override_pa": "", "credit_line_override_hi": ""}, {"id": 100043, "acmi_id": "E000066", "title": "Tektronix Oscilloscope Type 543A", "title_zh_hans": "", "title_pa": "", "title_hi": "", "title_annotation": "", "title_annotation_zh_hans": "", "title_annotation_pa": "", "title_annotation_hi": "", "slug": "tektroniks-oscilloscope-type-543a", "creator_credit": "", "credit_line": "", "credit_line_zh_hans": "", "cr