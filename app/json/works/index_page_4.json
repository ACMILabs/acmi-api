se, "first_production_date": "1902-01-01T10:00:00+10:00", "commissioned": false, "public_domain": false, "external_references": [], "brief_description": "<p>Melies&#8217; fantastical vision of life on the moon.</p>", "constellations_primary": [], "constellations_other": [{"id": 289, "name": "Space, sci-fi and cinema fakes", "description": "Magic lantern slides were used to entertain and educate audiences in home, theatres and universities. While performers told jokes and fairytales, travelling showmen unveiled exotic locations and scientists revealed the latest discoveries."}], "recommendations": [], "creator_credit_for_label": "<p>Georges Melies</p>", "headline_credit_for_label": "<p>France, 1902</p>", "title_for_label": "<p>Le Voyage dans la Lune (A Trip to the Moon)</p>", "description": "<p>One of the first Science Fiction films, this Melies’ short humorously proposes what man discovers when he first lands on the moon. Based on the Jules Verne story, George Melies used his extraordinary cinematic illusions to tell this story of the first voyage to the moon. Made in 1902, this was a visionary film that has come to be recognised as a cinematic masterpiece. Among the many comical set pieces is the famous scene in which a rocket ship crash-lands into the eye of the &#8216;man in the moon&#8217;. This whimsical fantasy is also exemplary in its early depiction of the moon and the possible encounters between humans and worlds beyond our imagining, in our exploration of deep space.</p>", "description_for_label": ["<p>One of the first Science Fiction films, this Melies’ short humorously proposes what man discovers when he first lands on the moon. Based on the Jules Verne story, George Melies used his extraordinary cinematic illusions to tell this story of the first voyage to the moon. Made in 1902, this was a visionary film that has come to be recognised as a cinematic masterpiece. Among the many comical set pieces is the famous scene in which a rocket ship crash-lands into the eye of the &#8216;man in the moon&#8217;. This whimsical fantasy is also exemplary in its early depiction of the moon and the possible encounters between humans and worlds beyond our imagining, in our exploration of deep space.</p>"], "credit_line_for_label": "", "details": [{"label": "Duration", "display_values": ["00:10:19:00"]}, {"label": "Language", "display_values": ["Silent"]}, {"label": "Audience classification", "display_values": ["Mediatheque - all ages (ACMI classified)"]}, {"label": "Subject categories", "display_values": ["Animation", "Fantasy & Science Fiction", "Fantasy & Science Fiction&nbsp;→ Science fiction films", "Short films", "Short films&nbsp;→ Short films - France", "Silent films"]}, {"label": "Sound/audio", "display_values": ["Silent"]}, {"label": "Colour", "display_values": ["Black and White"]}], "stats": {"tap_count": 326}, "links": [], "creators_primary": [{"id": 2709984, "name": "Georges Melies", "creator_id": 7067, "creator_wikidata_id": "Q121034641", "role": "creator", "role_id": 968, "is_primary": true}], "creators_other": [{"id": 2709985, "name": "Georges Melies", "creator_id": 7067, "creator_wikidata_id": "Q121034641", "role": "film maker", "role_id": 459, "is_primary": false}], "media_note": null, "holdings": [{"name": "DVD [PAL]; Copy", "identifier": "", "description": ""}, {"name": "DVD ROM; Copy", "identifier": "", "description": ""}, {"name": "Digital Betacam [PAL]; Master", "identifier": "", "description": ""}, {"name": "VHS [PAL]; Reference - timecoded", "identifier": "", "description": ""}, {"name": "MOV file H264; ACMI Digital Access Copy - presentation", "identifier": "", "description": ""}, {"name": "Digital Betacam [PAL]; Sub-master", "identifier": "", "description": ""}], "part_of": null, "parts": [], "part_siblings": [], "group": null, "group_works": [], "group_siblings": [], "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "442", "eaas_environment_id": null, "production_places": [{"id": 17, "