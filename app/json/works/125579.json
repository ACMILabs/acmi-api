{"id": 125579, "acmi_id": "", "title": "Frog Detective 2: The Case of the Invisible Wizard", "title_zh_hans": "", "title_pa": "", "title_hi": "", "title_annotation": "", "title_annotation_zh_hans": "", "title_annotation_pa": "", "title_annotation_hi": "", "slug": "frog-detective-2-the-case-of-the-invisible-wizard", "creator_credit": "Worm Club", "credit_line": "", "credit_line_zh_hans": "", "credit_line_pa": "", "credit_line_hi": "", "headline_credit": "Melbourne, Victoria, Australia, 2019", "video_links": [], "record_type": "group", "type": "Videogame", "is_on_display": false, "last_on_display_place": "ACMI", "last_on_display_date": "2027-07-30", "is_context_indigenous": false, "material_description": "", "unpublished": false, "external": false, "first_production_date": "2019-01-01T11:00:00+11:00", "commissioned": false, "public_domain": false, "external_references": [], "brief_description": "<p>Another mystery is afoot in <i>Frog Detective 2: The Case of the Invisible Wizard</i>. In the town of Warlock Woods, a parade welcoming the Invisible Wizard has been mysteriously destroyed. As the ‘second-best detective’, players interview a new cast of low-poly characters and follow clues through gentle, comic conversation.</p>", "constellations_primary": [{"id": 431, "name": "Soft-boiled detectives", "description": "This Constellation follows cosy mysteries where investigation is playful, social and a little strange. In these works, detectives question odd suspects, navigate anxious communities and solve cases where charm, humour and character matter just as much as the truth itself."}], "constellations_other": [], "recommendations": [], "creator_credit_for_label": "<p>Worm Club</p>", "creator_credit_for_label_zh_hans": "", "creator_credit_for_label_pa": "", "creator_credit_for_label_hi": "", "headline_credit_for_label": "<p>Melbourne, Victoria, Australia, 2019</p>", "headline_credit_for_label_zh_hans": "", "headline_credit_for_label_pa": "", "headline_credit_for_label_hi": "", "title_for_label_zh_hans": "", "title_for_label_pa": "", "title_for_label_hi": "", "title_for_label_override_zh_hans": "", "title_for_label_override_pa": "", "title_for_label_override_hi": "", "description_for_label_zh_hans": "", "description_for_label_pa": "", "description_for_label_hi": "", "description_for_label_override_zh_hans": "", "description_for_label_override_pa": "", "description_for_label_override_hi": "", "description_zh_hans": "", "description_pa": "", "description_hi": "", "description_override_zh_hans": "", "description_override_pa": "", "description_override_hi": "", "title_for_label": "<p>Frog Detective 2: The Case of the Invisible Wizard</p>", "description": "<p>Another mystery is afoot in <i>Frog Detective 2: The Case of the Invisible Wizard</i>. In the town of Warlock Woods, a parade welcoming the Invisible Wizard has been mysteriously destroyed. As the ‘second-best detective’, players interview a new cast of low-poly characters and follow clues through gentle, comic conversation.</p>\n<p>This second instalment expands the series’ play style with a detective notebook, letting players track interviews and mark residents as suspicious. Composer Dan Golding also develops the game’s playful jazz score, adding different instruments as Frog Detective meets each character. The result is a mystery shaped by humour, rhythm and care.</p>", "description_for_label": ["<p>Another mystery is afoot in <i>Frog Detective 2: The Case of the Invisible Wizard</i>. In the town of Warlock Woods, a parade welcoming the Invisible Wizard has been mysteriously destroyed. As the ‘second-best detective’, players interview a new cast of low-poly characters and follow clues through gentle, comic conversation.</p>\n<p>This second instalment expands the series’ play style with a detective notebook, letting players track interviews and mark residents as suspicious. Composer Dan Golding also develops the game’s playful jazz score, adding different instruments as Frog Dete