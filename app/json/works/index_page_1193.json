{"count": 41723, "next": "https://api.acmi.net.au/works/?page=1194", "previous": "https://api.acmi.net.au/works/?page=1192", "results": [{"id": 108346, "acmi_id": "B1002368", "title": "Substantial shadows", "title_annotation": "", "slug": "substantial-shadows", "creator_credit": "Lisl Ponger", "credit_line": "", "headline_credit": "Austria, 1987", "video_links": [], "record_type": "work", "type": "Film", "is_on_display": false, "last_on_display_place": null, "last_on_display_date": null, "is_context_indigenous": false, "material_description": "", "unpublished": false, "external": false, "first_production_date": "1987-01-01T11:00:00+11:00", "commissioned": false, "public_domain": false, "external_references": [], "brief_description": "<p>An elegant, silent meditation on different light forms as they emerge from and transform different obscure, shadowy environments. A miner&#8217;s torch flickers across the walls of a cave, a candle flame flickers in a shadow dance, a bonfire blazes in the darkness, a trail of artificial lights illuminate a kitsch architectural structure. Creating a montage that takes its rhythms from the waxing and waning motions of the different light sources Austrian artist Lisl Ponger proposes a playful and poetic contemplation of light and shadow and their qualities when captured as cinematic images.</p>", "constellations_primary": [], "constellations_other": [], "recommendations": [], "creator_credit_for_label": "<p>Lisl Ponger</p>", "headline_credit_for_label": "<p>Austria, 1987</p>", "title_for_label": "<p>Substantial shadows</p>", "description": "<p>An elegant, silent meditation on different light forms as they emerge from and transform different obscure, shadowy environments. A miner&#8217;s torch flickers across the walls of a cave, a candle flame flickers in a shadow dance, a bonfire blazes in the darkness, a trail of artificial lights illuminate a kitsch architectural structure. Creating a montage that takes its rhythms from the waxing and waning motions of the different light sources Austrian artist Lisl Ponger proposes a playful and poetic contemplation of light and shadow and their qualities when captured as cinematic images.</p>", "description_for_label": ["<p>An elegant, silent meditation on different light forms as they emerge from and transform different obscure, shadowy environments. A miner&#8217;s torch flickers across the walls of a cave, a candle flame flickers in a shadow dance, a bonfire blazes in the darkness, a trail of artificial lights illuminate a kitsch architectural structure. Creating a montage that takes its rhythms from the waxing and waning motions of the different light sources Austrian artist Lisl Ponger proposes a playful and poetic contemplation of light and shadow and their qualities when captured as cinematic images.</p>"], "credit_line_for_label": "", "details": [{"label": "Language", "display_values": ["German"]}, {"label": "Subject category", "display_values": ["Foreign language films"]}], "stats": {"tap_count": 0}, "links": [], "creators_primary": [{"id": 2748534, "name": "Lisl Ponger", "creator_id": 7374, "creator_wikidata_id": "Q1265730", "role": "director", "role_id": 938, "is_primary": true}, {"id": 2748533, "name": "Lisl Ponger", "creator_id": 7374, "creator_wikidata_id": "Q1265730", "role": "creator", "role_id": 968, "is_primary": true}, {"id": 2748536, "name": "Lisl Ponger", "creator_id": 7374, "creator_wikidata_id": "Q1265730", "role": "editor", "role_id": 918, "is_primary": true}], "creators_other": [{"id": 2748535, "name": "Lisl Ponger", "creator_id": 7374, "creator_wikidata_id": "Q1265730", "role": "photographer", "role_id": 440, "is_primary": false}, {"id": 2748537, "name": "Lisl Ponger", "creator_id": 7374, "creator_wikidata_id": "Q1265730", "role": "soundtrack", "role_id": 454, "is_primary": false}], "media_note": "Sorry, we don't have images or video for this item.", "holdings": [{"name": "Digital Betacam [PAL]; Sub-master", "identifier": "", "descri