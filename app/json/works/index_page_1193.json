r": "", "description": ""}, {"name": "Digital Betacam [PAL]; Sub-master", "identifier": "", "description": ""}, {"name": "VHS [PAL]; Reference - timecoded", "identifier": "", "description": ""}], "part_of": null, "parts": [], "part_siblings": [], "group": null, "group_works": [], "group_siblings": [], "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "700", "eaas_environment_id": null, "production_places": [{"id": 25, "name": "Hungary", "slug": "hungary"}], "production_dates": [{"date": "1992", "notes": "", "to_year": "1992"}], "labels": [47830]}, {"id": 108335, "acmi_id": "B1002335", "title": "The Diary of Mr. N: 1938-1967", "title_annotation": "", "slug": "the-diary-of-mr-n-1938-1967", "creator_credit": "Peter Forgacs and Marta Revesz", "credit_line": "", "headline_credit": "Hungary, 1990", "video_links": [], "record_type": "work", "type": "Film", "is_on_display": false, "last_on_display_place": null, "last_on_display_date": null, "is_context_indigenous": false, "material_description": "", "unpublished": false, "external": false, "first_production_date": "1990-01-01T11:00:00+11:00", "commissioned": false, "public_domain": false, "external_references": [], "brief_description": "<p>This film opens in the late thirties with the love affair and marriage of Mr N, a munitions engineer, to Ilona, a secretary at his factory. Over the next thirty years we see their lives unfold, as this energetic and outwards-looking man records his work, his leisure, and the violent political upheavals of his country.</p>\n<p>Like an epic novel, Mr N&#8217;s film diary has a huge cast of characters from all strata of society, a wide range of settings - both urban and rural, and every year or so, a new baby born to Ilona.</p>\n<p>Mr N films prolifically and without self-consciousness, documenting what intrigues, interests and impresses him. His family survives the 1944 seige of Budapest by spending winter in an air raid shelter; in &#8216;53 he films several of his eight children marching in a May Day rally; in &#8216;56 a crowd destroying a statue of Stalin; in &#8216;67 Ilona lying on a deck chair, reading a glamour magazine. An incredible record of personal stability through traumatic times.</p>", "constellations_primary": [], "constellations_other": [], "recommendations": [], "creator_credit_for_label": "<p>Peter Forgacs and Marta Revesz</p>", "headline_credit_for_label": "<p>Hungary, 1990</p>", "title_for_label": "<p>The Diary of Mr. N: 1938-1967</p>", "description": "<p>This film opens in the late thirties with the love affair and marriage of Mr N, a munitions engineer, to Ilona, a secretary at his factory. Over the next thirty years we see their lives unfold, as this energetic and outwards-looking man records his work, his leisure, and the violent political upheavals of his country.</p>\n<p>Like an epic novel, Mr N&#8217;s film diary has a huge cast of characters from all strata of society, a wide range of settings - both urban and rural, and every year or so, a new baby born to Ilona.</p>\n<p>Mr N films prolifically and without self-consciousness, documenting what intrigues, interests and impresses him. His family survives the 1944 seige of Budapest by spending winter in an air raid shelter; in &#8216;53 he films several of his eight children marching in a May Day rally; in &#8216;56 a crowd destroying a statue of Stalin; in &#8216;67 Ilona lying on a deck chair, reading a glamour magazine. An incredible record of personal stability through traumatic times.</p>", "description_for_label": ["<p>This film opens in the late thirties with the love affair and marriage of Mr N, a munitions engineer, to Ilona, a secretary at his factory. Over the next thirty years we see their lives unfold, as this energetic and outwards-looking man records his work, his leisure, and the violent political upheavals of his country.</p>\n<p>Like an epic novel, Mr N&#8217;s film diary has a huge cast of characters from all strata of society, a wide range of settings - both urban and rural, and every year or so, a new baby born to Ilona.</p>\n<p>Mr N films prolifically and without self-consciousness, documenting what intrigues, interests and impresses him. His family survives the 1944 seige of Budapest by spending winter in an air raid shelter; in &#8216;53 he films several of his eight children marching in a May Day rally; in &#8216;56 a crowd destroying a statue of Stalin; in &#8216;67 Ilona lying on a deck chair, reading a glamour magazine. An incredible record of personal stability through traumatic times.</p>"], "credit_line_for_label": "", "details": [{"label": "Duration", "display_values": ["00:51:00:00"]}, {"label": "Subject categories", "display_values": ["Amateur & Student Films", "Amateur & Student Films&nbsp;→ Amateur films", "Armed Forces, Military, War & Weapons&nbsp;→ War", "Armed Forces, Military, War & Weapons&nbsp;→ World War, 1939-1945", "Family, Gender Identity, Relationships & Sexuality&nbsp;→ Family", "Short films", "Short films&nbsp;→ Short films - Hungary"]}, {"label": "Colour", "display_values": ["Colour"]}], "stats": {"tap_count": 0}, "links": [], "creators_primary": [{"id": 2748496, "name": "Peter Forgacs", "creator_id": 6357, "creator_wikidata_id": null, "role": "creator", "role_id": 968, "is_primary": true}, {"id": 2748501, "name": "Marta Revesz", "creator_id": 73086, "creator_wikidata_id": "Q121223290", "role": "editor", "role_id": 918, "is_primary": true}], "creators_other": [{"id": 2748498, "name": "Tibor Szemzö", "creator_id": 73087, "creator_wikidata_id": "Q4415411", "role": "composer", "role_id": 538, "is_primary": false}], "media_note": null, "holdings": [{"name": "Digital Betacam [PAL]; Master", "identifier": "", "description": ""}, {"name": "Digital Betacam [PAL]; Sub-master", "identifier": "", "description": ""}, {"name": "VHS [PAL]; Reference - timecoded", "identifier": "", "description": ""}, {"name": "MOV file ProRes4444; Digital Preservation Master - overscan", "identifi