or", "role_id": 938, "is_primary": true}, {"id": 3106929, "title": "Blue", "work_id": 108652, "role": "producer", "role_id": 1089, "is_primary": true}], "also_known_as": "", "date_of_birth": "28 MAY 1959", "date_of_death": "", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [{"id": 1, "name": "English", "slug": "english"}], "places_of_operation": [{"id": 36, "name": "Canada", "slug": "canada"}], "biography": "Bruce McDonald (born May 28, 1959) is a Canadian film and television director, writer, and producer. Born in Kingston, Ontario, he rose to prominence in the 1980s as part of the loosely-affiliated Toronto New Wave.McDonald has directed more than a dozen features films over the course of his three-decade-long filmmaking career. The Hollywood Reporter has called him an \"iconoclastic filmmaker\". Several of his films, ranging from mockumentaries to horror films, have attracted cult followings. His most notable films include Roadkill (1989), Highway 61 (1991), Hard Core Logo (1996), Pontypool (2008), Trigger (2010), and Hellions (2015). Hard Core Logo has been frequently ranked amongst the greatest movies ever to come out of Canada. Source: Wikidata; 01/08/2023", "biography_author": null, "date_of_biography": "2025-08-20T15:08:32.474398+10:00", "external_links": [{"id": 3688, "uri": "https://en.wikipedia.org/wiki/Bruce_McDonald_(director)"}], "uuid": "2e8d72a6-58b7-42e2-89c4-08c9c6f40e06", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "1731", "external_references": [{"id": 25362, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q1249881"}, {"id": 27620, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "53743703"}, {"id": 27621, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "no96028659"}, {"id": 27622, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-no96028659"}], "date_modified": "2025-08-20T15:08:32.474639+10:00"}, {"id": 