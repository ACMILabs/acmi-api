kidata", "date_of_biography": "2023-08-01T14:06:37.884176+10:00", "external_links": [{"id": 3589, "uri": "https://en.wikipedia.org/wiki/Arthur_Crabtree"}], "uuid": "62450ef3-0c95-4282-8b4b-a7e27e1a70b6", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "15521", "external_references": [{"id": 26624, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q709019"}, {"id": 27365, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "5124149108587068780002"}, {"id": 27366, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "nr97041887"}, {"id": 27367, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-nr97041887"}], "date_modified": "2023-09-05T17:46:36.096010+10:00"}, {"id": 77051, "name": "Gregory Read", "roles_in_work": [{"id": 2204576, "title": "Photographers of Australia: Dupain, Sievers, Moore", "work_id": 82109, "role": "director", "role_id": 938, "is_primary": true}, {"id": 2204575, "title": "Photographers of Australia: Dupain, Sievers, Moore", "work_id": 82109, "role": "co-producer", "role_id": 915, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [], "places_of_operation": [], "biography": "Gregory J. Read is an Australian filmmaker.\nRead started his film career writing, directing, producing and editing the documentaries Spirits of the Carnival, Tides of Passage, and Photographers of Australia: Dupain, Sievers, Moore. In 2006 Read wrote and directed Like Minds starring Eddie Redmayne (in his feature film début), Tom Sturridge, Toni Collette and Richard Roxburough.\nAlthough Like Minds was Read's directorial feature film début,  he had assisted in the production of many low-budget Australian features and directed, produced and/or art directed may television commercials and Music videos for performers such as Kate Ceberano, Iva Davis, Grant McLennon and the Divinyls.\nIn 2008 Gregory established Aerial Film Australia, an specialist aerial company with credits on films such as, Unbroken, San Andreas (film), Pirates of the Caribbean: Dead Men Tell No Tales, Alien: Covenant, Lion, The Meg, The Shallows, Peter Rabbit, Pacific Rim: Uprising, Aquaman and Spiderhead.\nIn 2011 Gregory produced with Anthony Waddington the multi award-winning Fred Schepisi directed film The Eye of the Storm (2011 film)\n2007-2018 Gregory wrote, shot and directed the Australian Writers' Guild (AWGIE) award-winning (2020) feature documentary, Own the Sky chronicling David Mayman's epic journey in the development of the world's first real Jetpack. 2018 Gregory shot, field directed and associate produced the Akos Armont directed feature documentary Brabham (2020).", "biography_author": "Wikidata", "date_of_biography": "2023-08-01T15:05:50.288730+10:00", "external_links": [{"id": 4110, "uri": "https://en.wikipedia.org/wiki/Gregory_J._Read"}], "uuid": "8ec60c9c-98fc-4784-8efe-dc141bf6871d", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "20088", "external_references": [{"id": 26510, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q5606993"}, {"id": 28781, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "94263136"}, {"id": 28782, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-no2008012026"}], "date_modified": "2023-09-05T20:23:17.762356+10:00"}, {"id": 77050, "name": "Wolfgang Knochell", "roles_in_work": [{"id": 2204573, "title": "Photographers of Australia: Dupain, Sievers, Moore", "work_id": 82109, "role": "co-producer", "role_id": 915, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": "2023-05-09T15:32:08.364390+10:00", "external_links": [], "uuid": "48a53afb-3bcf-4178-a133-e9b0b53e86c4", "source": {