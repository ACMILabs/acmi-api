role": "co-producers/directors", "role_id": 628, "is_primary": true}, {"id": 2250510, "title": "Ripping yarns", "work_id": 83689, "role": "director", "role_id": 938, "is_primary": true}, {"id": 2354648, "title": "The Hitchhiker's guide to the galaxy. Volume 2", "work_id": 85708, "role": "producer/director", "role_id": 31, "is_primary": true}, {"id": 1847273, "title": "Hitchhiker's guide to the galaxy. - Volume 1.", "work_id": 85242, "role": "producer/director", "role_id": 31, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": "2023-05-09T20:01:54.067682+10:00", "external_links": [], "uuid": "699bf32a-705f-4414-82b6-eb376bc357b3", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "14766", "external_references": [], "date_modified": "2023-06-14T16:33:30.576250+10:00"}, {"id": 25806, "name": "Peter Hall", "roles_in_work": [{"id": 3086705, "title": "The Homecoming", "work_id": 95114, "role": "director", "role_id": 938, "is_primary": true}, {"id": 885536, "title": "L'incoronazione di Poppea", "work_id": 95383, "role": "director", "role_id": 938, "is_primary": true}, {"id": 2335421, "title": "The Camomile lawn", "work_id": 83687, "role": "director", "role_id": 938, "is_primary": true}, {"id": 2178715, "title": "Orfeo and Euridice", "work_id": 95424, "role": "co-producer", "role_id": 915, "is_primary": true}], "also_known_as": "Peter Reginald Frederick Hall", "date_of_birth": "22 NOV 1930", "date_of_death": "11 SEP 2017", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [{"id": 1, "name": "English", "slug": "english"}], "places_of_operation": [{"id": 10, "name": "United Kingdom", "slug": "united-kingdom"}], "biography": "Sir Peter Reginald Frederick Hall CBE (22 November 1930 – 11 September 2017) was an English theatre, opera and film director. His obituary in The Times declared him \"the most important figure in British theatre for half a century\" and on his death, a Royal National Theatre statement declared that Hall's \"influence on the artistic life of Britain in the 20th century was unparalleled\". In 2018, the Laurence Olivier Awards, recognizing achievements in London theatre, changed the award for Best Director to the Sir Peter Hall Award for Best Director.\n\nIn 1955, Hall introduced London audiences to the work of Samuel Beckett with the UK premiere of Waiting for Godot. Hall founded the Royal Shakespeare Company (1960–68) and went on to build an international reputation in theatre, opera, film and television. He was director of the National Theatre (1973–88) and artistic director of Glyndebourne Festival Opera (1984–1990). He formed the Peter Hall Company (1998–2011) and became founding director of the Rose Theatre Kingston in 2003. Throughout his career, he was a tenacious champion of public funding for the arts. Source: Wikidata; 01/08/2023", "biography_author": null, "date_of_biography": "2025-03-17T10:45:35.934399+11:00", "external_links": [{"id": 4880, "uri": "https://en.wikipedia.org/wiki/Peter_Hall_(director)"}], "uuid": "cab19be1-12ff-405f-86d8-0e7ba37d3611", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "26568", "external_references": [{"id": 26626, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q769414"}, {"id": 30788, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "64047197"}, {"id": 30789, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "n83042353"}, {"id": 30790, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-n83042353"}], "date_modified": "2025-03-17T10:45:35.934711+11:00"}, {"id": 25805, "name": "Glenn Wilhide", "roles_in_work": [{"id": 2335414, "title": "The Camomile lawn", "work_id": 83687, "role": "co-producer", "role_id": 915, "is_primary": true}, {"id": 1819971, "title": "The Royle famil