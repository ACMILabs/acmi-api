ces": [{"id": 41305, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q121270933"}], "date_modified": "2023-09-06T02:12:16.799641+10:00"}, {"id": 27111, "name": "Jerry Lewis", "roles_in_work": [{"id": 1989471, "title": "The Nutty professor", "work_id": 85187, "role": "director", "role_id": 938, "is_primary": true}, {"id": 2350438, "title": "The Geisha boy", "work_id": 93466, "role": "producer", "role_id": 1089, "is_primary": true}, {"id": 2358139, "title": "The Ladies man", "work_id": 94343, "role": "producer/director", "role_id": 31, "is_primary": true}], "also_known_as": "Joseph Levitch", "date_of_birth": "1926-03-16", "date_of_death": "2017-08-20", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [{"id": 1, "name": "English", "slug": "english"}], "places_of_operation": [{"id": 1, "name": "United States of America", "slug": "united-states-of-america"}], "biography": "Jerry Lewis (born Joseph Levitch; March 16, 1926 – August 20, 2017) was an American comedian, actor, singer, director, producer, writer and humanitarian. Nicknamed \"The King of Comedy\", Lewis is regarded as one of the most significant American cultural figures of the 20th century. Widely known for his \"kid\" and \"idiot\" persona, his contributions to comedy and charity, along with his publicized personal life made him a global figure in pop culture over an eight-decade career. He professionally debuted in 1946 as part of the famous Martin and Lewis with singer Dean Martin and performed with him until 1956, then went solo after the split. \nBy becoming the highest grossing movie star and innovative filmmaker, he helped to develop and popularize \"video assist\", the closed-circuit apparatus enabling film directors to see what had been shot without waiting for developed film footage. In addition to starring in sixty films, Lewis directed 13 movies. He was also national chairman of the Muscular Dystrophy Association (MDA) and host of The Jerry Lewis Telethon each Labor Day weekend for many years.", "biography_author": "Wikidata", "date_of_biography": "2022-05-19T11:57:58.520215+10:00", "external_links": [{"id": 2377, "uri": "https://en.wikipedia.org/wiki/Jerry_Lewis"}], "uuid": "3678ba4e-743e-4e75-bc90-49b090beb448", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "21805", "external_references": [{"id": 10185, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q294927"}, {"id": 10186, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "98006568"}, {"id": 10187, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "n50053444"}, {"id": 10188, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-n50053444"}], "date_modified": "2023-09-13T12:30:25.990078+10:00"}, {"id": 27108, "name": "ATP", "roles_in_work": [{"id": 2788625, "title": "Look up and laugh", "work_id": 85185, "role": "production company", "role_id": 941, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": "2023-05-09T20:07:57.563216+10:00", "external_links": [], "uuid": "b8be66ef-f027-4013-a649-182b783bd164", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "5514", "external_references": [{"id": 34916, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q121337670"}], "date_modified": "2025-03-14T19:45:11.261613+11:00"}, {"id": 27107, "name": "Paul N Lazarus", "roles_in_work": [{"id": 2615286, "title": "Capricorn one", "work_id": 85184, "role": "producer", "role_id": 1089, "is_primary": true}], "also_known_as": "", "date_of_birth": "1938-05-25", "date_of_death": null, "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [], "places_of_operation": [{"id": 1, "name": "United States of America", "slug": "united-states-of-america"}], "biography": "Paul N. Lazarus III is an American film producer.In the 1960s he was an agent, his clients including Woody Allen. He ran his own production company and became chief of production for the film division of HBO. He spent a year as director of the New Mexico Film Commission then went to work for the University of Miami.In 1985 he published a book The Film Producer: A Handbook for Producing.", "biography_author": "Wikidata", "date_of_biography": "2022-05-19T12:39:45+10:00", "external_links": [{"id": 2830, "uri": "https://en.wikipedia.org/wiki/Paul_N._Lazarus_III"}], "uuid": "98c5ddfa-4bc0-4e5d-8951-a500ae1a0f0c", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "26299", "external_references": [{"id": 12050, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q2060877"}, {"id": 12051, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "92840538"}, {"id": 12052, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "n84203991"}, {"id": 12053, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-n84203991"}], "date_modified": "2025-02-26T20:21:46.997418+11:00"}, {"id": 27106, "name": "Associated General Films", "roles_in_work": [{"id": 2615285, "title": "Capricorn one", "work_id": 85184, "role": "production company", "role_id": 941, "is_primary": true}, {"id": 1989613, "title": "Voyage of the damned", "work_id": 85317, "role": "production company", "role_id": 941, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": "2023-05-09T13:17:58.983886+10:00", "external_links": [], "uuid": "794e513f-4487-4205-9c59-befdb62b61b5", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "5463", "external_references": [{"id": 43496, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q121337303"}], "date_modified": "2025-02-26T20:21:46.411478+11:00"}, {"id": 27101, "name": "Louis D Lighton", "roles_in_work": [{"id": 2130013, "title": "Captains Courageous", "work_id": 85182, "role": "director", "role_id": 938, "is_primary": true}, {"id": 1809976, "title": "A Tree grows in Brooklyn [NTSC]", "work_id": 94502, "role": "producer", "role_id": 1089, "is_primary": true}], "also_known_as": "", "date_of_birth": "1895-11-25", "date_of_death": "1963-02-01", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [], "places_of_operation": [{"id": 1, "name": "United States of America", "slug": "united-states-of-america"}], "biography": "Louis D. Lighton (November 25, 1895 – February 1, 1963) was an American screenwriter and producer. He wrote for 40 films between 1920 and 1927. He also produced 30 films between 1928 and 1951. He was born in Omaha, Nebraska and died in Palma de Mallorca, Spain. He was married to fellow screenwriter Hope Loring.", "biography_author": "Wikidata", "date_of_biography": "2023-09-05T22:31:04.819929+10:00", "external_links": [{"id": 5983, "uri": "https://en.wikipedia.org/wiki/Louis_D._Lighton"}], "uuid": "7e7fa85e-9f59-4f42-aee9-6a3d21ce4c10", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "24014", "external_references": [{"id": 51074, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q5104089"}, {"id": 55090, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "48201217"}, {"id": 55091, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "n85151835"}, {"id": 55092, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-n85151835"}], "date_modified": "2023-09-05T22:31:04.840383+10:00"}]}