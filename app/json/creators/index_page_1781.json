{"count": 28683, "next": "https://api.acmi.net.au/creators/?page=1782", "previous": "https://api.acmi.net.au/creators/?page=1780", "results": [{"id": 26768, "name": "Sarah Ferguson, Duchess of York", "roles_in_work": [{"id": 2126285, "title": "Budgie the little helicopter. - Volume 1.", "work_id": 84888, "role": "production company", "role_id": 941, "is_primary": true}, {"id": 2126312, "title": "Budgie the little helicopter. - Volume 2.", "work_id": 85156, "role": "production company", "role_id": 941, "is_primary": true}], "also_known_as": "Sarah Margaret Ferguson", "date_of_birth": "1959-10-15", "date_of_death": "", "genders": [{"id": 5, "name": "Female", "slug": "female"}], "languages": [{"id": 1, "name": "English", "slug": "english"}], "places_of_operation": [{"id": 10, "name": "United Kingdom", "slug": "united-kingdom"}], "biography": "Sarah, Duchess of York (born Sarah Margaret Ferguson; 15 October 1959), also known by the nickname Fergie, is a British author, television personality, and member of the British royal family. She is the former wife of Prince Andrew, Duke of York, a younger brother of King Charles III.\nShe was raised in Dummer, Hampshire, and attended the Queen's Secretarial College. She later worked for public relations firms in London, and then for a publishing company. Ferguson began a relationship with Prince Andrew in 1985, and they were married on 23 July 1986 at Westminster Abbey. They have two daughters, Princess Beatrice and Princess Eugenie. Their marriage, separation in 1992, and divorce in 1996 attracted much media coverage.\nBoth during and after her marriage, Sarah has been involved with several charities as a patron and spokesperson. Her charity work primarily revolves around helping cancer patients and children. She has been the patron of Teenage Cancer Trust since 1990 and founded Children in Crisis and Sarah's Trust. In the years after her divorce, Sarah was the subject of scandals that affected her relationship with the royal family, but she has appeared in various royal events in recent years. She has written several books for children and adults and has worked on TV and in film production.", "biography_author": "Wikidata", "date_of_biography": "2023-09-06T01:05:51.365424+10:00", "external_links": [{"id": 6167, "uri": "https://en.wikipedia.org/wiki/Sarah,_Duchess_of_York"}], "uuid": "959b0b80-64d7-4138-ad09-4a5ece1d9d28", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "20643", "external_references": [{"id": 39739, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q55720"}, {"id": 55770, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "41953880"}, {"id": 55771, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "n86101487"}, {"id": 55772, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-n86101487"}], "date_modified": "2023-09-06T01:05:57.541135+10:00"}, {"id": 26766, "name": "Sleepy Kids", "roles_in_work": [{"id": 2126277, "title": "Budgie the little helicopter. - Volume 1.", "work_id": 84888, "role": "production company", "role_id": 941, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": "2023-05-09T13:11:26.033812+10:00", "external_links": [], "uuid": "7377902c-1e84-4c72-8ffb-e4056b8e1855", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "13453", "external_references": [], "date_modified": "2023-06-14T16:33:30.576250+10:00"}, {"id": 26764, "name": "Nadine Welter", "roles_in_work": [{"id": 2615139, "title": "Italianissimo 2: intermediate: a multimedia course for learning Italian", "work_id": 84886, "role": "producer", "role_id": 1089, "is_primary": true}], "also_known_as": "", "date_of_birth": null, "date_of_death": null, "genders": [], "languages": [], "places_of_operation": [], "biography": "", "bio