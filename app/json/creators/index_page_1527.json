igan", "roles_in_work": [{"id": 2326273, "title": "The Acid house (D)", "work_id": 91471, "role": "director", "role_id": 938, "is_primary": true}, {"id": 1995852, "title": "Gangster no. 1", "work_id": 92348, "role": "director", "role_id": 938, "is_primary": true}], "also_known_as": "", "date_of_birth": "1963-09-19", "date_of_death": "", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [{"id": 1, "name": "English", "slug": "english"}], "places_of_operation": [{"id": 10, "name": "United Kingdom", "slug": "united-kingdom"}], "biography": "Paul McGuigan (born 19 September 1963) is a Scottish film and television director, best known for directing films such as Lucky Number Slevin, Gangster No. 1 and Push. He has also directed episodes of Sherlock, Scandal,  Monroe and Smash. He was born in Bellshill Maternity Hospital, Scotland.", "biography_author": "Wikidata", "date_of_biography": "2023-08-01T16:30:33.981563+10:00", "external_links": [{"id": 4847, "uri": "https://en.wikipedia.org/wiki/Paul_McGuigan_(filmmaker)"}], "uuid": "f41129e3-dfe5-4d77-b5ef-01f6335da531", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "26290", "external_references": [{"id": 26048, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q1377534"}, {"id": 30704, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "84320314"}, {"id": 30705, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "no2006094799"}, {"id": 30706, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-no2006094799"}], "date_modified": "2023-09-05T23:48:18.406495+10:00"}, {"id": 32947, "name": "Segma Limited", "roles_in_work": [{"id": 2240674, "title": "Final Cut", "work_id": 91470, "role": "production company", "role_id": 941, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": "2023-05-09T16:53:06.008611+10:00", "external_links": [], "uuid": "615ffc53-9b33-4523-ad12-1a57240230c5", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "12412", "external_references": [{"id": 37654, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q121126743"}], "date_modified": "2023-09-06T01:09:51.648367+10:00"}, {"id": 32940, "name": "Dean Parisot", "roles_in_work": [{"id": 2475037, "title": "Galaxy quest", "work_id": 91467, "role": "director", "role_id": 938, "is_primary": true}], "also_known_as": "Aldo Luis Parisot", "date_of_birth": "1952-07-06", "date_of_death": null, "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [{"id": 1, "name": "English", "slug": "english"}], "places_of_operation": [{"id": 1, "name": "United States of America", "slug": "united-states-of-america"}], "biography": "Aldo Luis \"Dean\" Parisot (born July 6, 1952) is an American film and television director. He won the 1988 Academy Award for Best Live Action Short Film for The Appointments of Dennis Jennings, which was co-written by and starred comedian Steven Wright, with whom he shares the award. Among his television credits are episodes of Monk (including the two-hour pilot \"Mr. Monk and the Candidate\"), Northern Exposure and Curb Your Enthusiasm.\nParisot was born in Wilton, Connecticut, to Ellen James (née Lewis), a painter and art teacher, and Aldo Parisot, a Brazilian-born, well-known cellist and pedagogue. \nHe graduated from New York University's Tisch School of the Arts. He took part in the Sundance Institute's June Lab.\nIn 2012, he was hired to direct the third installment of the Bill and Ted franchise. The film, Bill & Ted Face the Music, was released on August 28, 2020.Parisot was married to film editor Sally Menke until her death in 2010; they had two children.", "biography_author": "Wikidata", "date_of_biography": "2023-08-01T14:36:56.631837+10:00", "external_links": [{"id": 3861, "u