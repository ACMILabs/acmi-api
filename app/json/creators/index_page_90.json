{"count": 28687, "next": "https://api.acmi.net.au/creators/?page=91", "previous": "https://api.acmi.net.au/creators/?page=89", "results": [{"id": 86076, "name": "Darren Almond", "roles_in_work": [{"id": 2637455, "title": "A (Darren Almond)", "work_id": 119727, "role": "creator", "role_id": 968, "is_primary": true}], "also_known_as": "", "date_of_birth": "1971", "date_of_death": "", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [], "places_of_operation": [], "biography": "Darren Almond's practice encompasses sculpture, film, photography and drawing.  Almond has had solo exhibitions at K21 Kunstsammlung Nordrhein-Westfalen, Dusseldorf; Lentos Kunstmuseum Linz, Linz; Fondazione Nicola Trussardi, Milan; Tate Modern, London; De Appel, Amsterdam; the Kunsthalle, Zurich; The Renaissance Society, Chicago; and the Institute of Contemporary Arts, London.\n\nRecent group shows include Universal Experience: Art, Life and the Tourist's Eye, Museum of Contemporary Art, Chicago; Delays and Revolutions, 50th Venice Biennale, Venice; Moving Pictures, Solomon R. Gugghenheim Museum, New York; and Apocalypse: Beauty and Horror in Contemporary Art, Royal Academy of Arts, London.  Almond lives and works in London.  (SW 30.03.05)", "biography_author": null, "date_of_biography": "2025-03-05T10:46:55.882532+11:00", "external_links": [], "uuid": "d47eb84e-bb1a-4a9e-8375-f0b49ab99394", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "2356", "external_references": [], "date_modified": "2025-03-05T10:46:55.882759+11:00"}, {"id": 86075, "name": "Mario Ruccione", "roles_in_work": [{"id": 2658878, "title": "What Will Come (has already come)", "work_id": 49985, "role": "music", "role_id": 949, "is_primary": false}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": "2023-08-14T12:44:02.524697+10:00", "external_links": [],