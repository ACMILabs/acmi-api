nders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [{"id": 4, "name": "French", "slug": "french"}], "places_of_operation": [{"id": 8, "name": "Japan", "slug": "japan"}], "biography": "Hiroyuki Kitakubo (北久保 弘之, Kitakubo Hiroyuki, born November 15, 1963) is a Japanese director, animator, and screenwriter.\nKitakubo began work in the anime industry as a teenager, having worked on the 1979 Mobile Suit Gundam television series. He debuted as a director with the Cream Lemon episode \"Pop Chaser\" in 1985, then worked on films including Black Magic M-66 with Masamune Shirow and Akira with Katsuhiro Otomo. Kitakubo went on to direct the \"A Tale of Two Robots\" segment from Robot Carnival, the original video animation (OVA) series Golden Boy, and the films Roujin Z and Blood: The Last Vampire. In 2001, Kitakubo won the \"Individual Award\" at The 6th Animation Kobe for the latter film. Blood: The Last Vampire also won grand prize at the 2000 Japan Media Arts Festival and first prize the  2001 World Animation Celebration.", "biography_author": "Wikidata", "date_of_biography": "2023-08-01T15:11:49.980064+10:00", "external_links": [{"id": 4162, "uri": "https://en.wikipedia.org/wiki/Hiroyuki_Kitakubo"}], "uuid": "007e12bf-39f2-4847-92bb-cf7bc27ec7cd", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "20581", "external_references": [{"id": 26231, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q3136396"}, {"id": 28929, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "2677924"}, {"id": 28930, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "no2004050430"}, {"id": 28931, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-no2004050430"}], "date_modified": "2023-09-05T20:40:18.849187+10:00"}, {"id": 34455, "name": "Production IG", "roles_in_work": [{"id": 2120716, "title": "Blood: the last vampire", "work_id": 92755, "role": "production company", "role_