], "languages": [{"id": 19, "name": "Arabic", "slug": "arabic"}, {"id": 78, "name": "Egyptian Arabic", "slug": "egyptian-arabic"}, {"id": 1, "name": "English", "slug": "english"}], "places_of_operation": [{"id": 182, "name": "Egypt", "slug": "egypt"}], "biography": "Mahmoud Qasdy Ahmed Mourad Zulfikar (18 February 1914 – 22 May 1970) was an Egyptian film director, producer, screenwriter, and actor. He was a major figure in Egyptian film industry.He started his career as an architect, before becoming an actor in 1939. Zulfikar was one of the most prominent artists in Egyptian cinema, he was known for his boldness and adventure with the new talents he presented to the Egyptian audience, later, he was nicknamed the \"Talent Finder\". Zulfikar was able to go beyond the limits of the film location with accurate calculations and through his imaginations, he could make his scripts alive. This earned him in Egypt the nickname of \"The Event Maker\".", "biography_author": "Wikidata", "date_of_biography": "2023-08-01T16:01:31.137369+10:00", "external_links": [{"id": 4591, "uri": "https://en.wikipedia.org/wiki/Mahmoud_Zulfikar"}], "uuid": "5882a288-1e57-4988-bc91-c425f29fc39e", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "24196", "external_references": [{"id": 26548, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q4884383"}, {"id": 30056, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "66272222"}, {"id": 30057, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "no2008029244"}, {"id": 30058, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-no2008029244"}], "date_modified": "2023-09-13T12:31:07.682448+10:00"}, {"id": 33491, "name": "St George Migrant Resource Centre", "roles_in_work": [{"id": 2465666, "title": "Sense of home: getting older in a new country", "work_id": 92301, "role": "production company", "role_id": 941, "is_primary": true}], "also_known_as"