{"count": 28683, "next": "https://api.acmi.net.au/creators/?page=728", "previous": "https://api.acmi.net.au/creators/?page=726", "results": [{"id": 78309, "name": "Nat Perrin", "roles_in_work": [{"id": 2331116, "title": "The Best of the Addams Family. -Volume 5", "work_id": 86661, "role": "producer", "role_id": 1089, "is_primary": true}, {"id": 2330957, "title": "The Best of the Addams Family. -Volume 4", "work_id": 86662, "role": "producer", "role_id": 1089, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": "2023-05-09T19:25:42.800456+10:00", "external_links": [], "uuid": "e3281247-1908-447b-a5a9-036f1ccf8dd7", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "25637", "external_references": [{"id": 32363, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q121035327"}], "date_modified": "2023-09-05T23:25:18.329225+10:00"}, {"id": 78308, "name": "Billy Bob Thornton", "roles_in_work": [{"id": 2302898, "title": "Sling blade", "work_id": 86658, "role": "director", "role_id": 938, "is_primary": true}, {"id": 2085999, "title": "All the pretty horses", "work_id": 92465, "role": "director", "role_id": 938, "is_primary": true}, {"id": 2085997, "title": "All the pretty horses", "work_id": 92465, "role": "co-producer", "role_id": 915, "is_primary": true}], "also_known_as": "William Robert Thornton", "date_of_birth": "1955-08-04", "date_of_death": "", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [{"id": 1, "name": "English", "slug": "english"}], "places_of_operation": [{"id": 1, "name": "United States of America", "slug": "united-states-of-america"}], "biography": "Billy Bob Thornton (born August 4, 1955) is an American film actor and director. He had his first break when he co-wrote and starred in the 1992 thriller One False Move, and received international attention after writing, directing, and starring in the independent drama film Sling Blade (1996), for which he won an Academy Award for Best Adapted Screenplay and was nominated for an Academy Award for Best Actor. He appeared in several major film roles in the 1990s following Sling Blade, including Oliver Stone's neo-noir U Turn (1997), political drama Primary Colors (1998), science fiction disaster film Armageddon (1998), the highest-grossing film of that year, and the crime drama A Simple Plan (1998), which earned him his third Oscar nomination.\nIn the 2000s, Thornton achieved further success starring in dramas Monster's Ball (2001), The Man Who Wasn't There (2001), and Friday Night Lights (2004); and comedy films, Intolerable Cruelty (2003), and Bad Santa (2003). In 2014, Thornton starred as Lorne Malvo in the first season of the anthology series Fargo, earning a nomination for the Outstanding Lead Actor in a Miniseries or TV Movie at the Emmy Awards and won Best Actor in a Miniseries or TV Film at the 72nd Golden Globe Awards. In 2016–2021 he starred for four seasons in an Amazon original series, Goliath, which earned him a Golden Globe Award for Best Actor – Television Series Drama.\nThornton has written a variety of films, usually set in the Southern United States and mainly co-written with Tom Epperson, including A Family Thing (1996) and The Gift (2000). After Sling Blade, he directed several other films, including Daddy and Them (2001), All the Pretty Horses (2000), and Jayne Mansfield's Car (2012).\nThornton has received the President's Award from the Academy of Science Fiction, Fantasy & Horror Films, a Special Achievement Award from the National Board of Review, and a star on the Hollywood Walk of Fame. He has also been nominated for an Emmy Award, four Golden Globes, and three Screen Actors Guild Awards. In addition to film work, Thornton began a career as a singer-songwriter. He has released four solo albums and is the vocalist of the rock band the Boxmasters.\nThornton has been vocal about his distaste for celebrity culture, choosing to keep out of the public eye. He was unable to avoid media intrusion concerning his marriage to Angelina Jolie.", "biography_author": "Wikidata", "date_of_biography": "2023-08-01T14:13:47.984084+10:00", "external_links": [{"id": 1731, "uri": "https://en.wikipedia.org/wiki/Billy_Bob_Thornton"}], "uuid": "eb2b870d-f33b-4d48-b4f9-6b9ab3543f7d", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "16024", "external_references": [{"id": 7551, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q202735"}, {"id": 7552, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "54344355"}, {"id": 7553, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "n96086136"}, {"id": 7554, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-n96086136"}], "date_modified": "2023-09-05T18:05:09.884930+10:00"}, {"id": 78307, "name": "David L. Bushell", "roles_in_work": [{"id": 2302895, "title": "Sling blade", "work_id": 86658, "role": "co-producer", "role_id": 915, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": "2023-05-09T18:40:09.711218+10:00", "external_links": [], "uuid": "117a9b20-7565-4ef9-af5b-388d66c38b17", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "17674", "external_references": [{"id": 39589, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q121143883"}], "date_modified": "2023-09-05T18:59:29.838720+10:00"}, {"id": 78306, "name": "Brandon Rosser", "roles_in_work": [{"id": 2302892, "title": "Sling blade", "work_id": 86658, "role": "co-producer", "role_id": 915, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_