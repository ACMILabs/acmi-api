ole": "producer", "role_id": 1089, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": "2023-05-09T18:57:48.850891+10:00", "external_links": [], "uuid": "39f89f61-1f4b-4516-a22e-e6d9b306cffa", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "22145", "external_references": [], "date_modified": "2025-03-13T00:15:20.455119+11:00"}, {"id": 17125, "name": "Stuart Burge", "roles_in_work": [{"id": 2152875, "title": "Julius Caesar (Heston/Gielgud)", "work_id": 85084, "role": "director", "role_id": 938, "is_primary": true}, {"id": 749918, "title": "Othello", "work_id": 71226, "role": "director", "role_id": 938, "is_primary": true}, {"id": 2754440, "title": "Uncle Vanya", "work_id": 99204, "role": "director", "role_id": 938, "is_primary": true}, {"id": 2321795, "title": "Talking heads by Alan Bennett", "work_id": 90706, "role": "co-director", "role_id": 959, "is_primary": true}], "also_known_as": "Stuart Masters Haig Burge", "date_of_birth": "15 JAN 1918", "date_of_death": "24 JAN 2002", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [{"id": 1, "name": "English", "slug": "english"}], "places_of_operation": [{"id": 10, "name": "United Kingdom", "slug": "united-kingdom"}], "biography": "Stuart Burge  (15 January 1918 – 24 January 2002) was an English stage and film director, actor and producer.The son of H. O. Burge, by his marriage to K. M. Haig, Burge was educated at Eagle House School, Sandhurst, and Felsted School, Essex, then trained for an acting career at the Old Vic, 1936–37, and at Oxford Rep, 1937–38. He was back at the Old Vic and appearing in the West End theatre in 1938–39, then during the Second World War of 1939–45 he served in the British Army's Intelligence Corps. After the war he returned to his acting career at the Bristol Old Vic, the Young Vic, and the Commercial Theatre, between 1946 and 1949.He was a director by 1948. He was responsible for many distinguished productions for both stage and television, including four film adaptations of plays.\n\nHe married Josephine Parker an American Actress and had five children: Lucy Burge, Stephen Burge, Nicholas Burge, Matthew Burge and Emma Burge. Source: Wikidata; 01/08/2023", "biography_author": null, "date_of_biography": "2025-03-13T01:45:10.519531+11:00", "external_links": [{"id": 5214, "uri": "https://en.wikipedia.org/wiki/Stuart_Burge"}], "uuid": "280e3c1b-5620-4018-83db-739d00ffbfbc", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "29246", "external_references": [{"id": 26294, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q3500781"}, {"id": 31658, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "51324833"}, {"id": 31659, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "no99049649"}, {"id": 31660, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-no99049649"}], "date_modified": "2025-03-13T01:45:10.519845+11:00"}]}