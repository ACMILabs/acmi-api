 4950, "uri": "https://en.wikipedia.org/wiki/Raoul_Servais"}], "uuid": "b19acbe9-0201-4b0a-9629-6afa0a366471", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "27126", "external_references": [{"id": 25566, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q1394440"}, {"id": 30981, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "95662219"}, {"id": 30982, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "n81008073"}, {"id": 30983, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-n81008073"}], "date_modified": "2025-03-13T00:00:21.436062+11:00"}, {"id": 13827, "name": "Ministry of National Education and Culture (Brussels)", "roles_in_work": [{"id": 2644391, "title": "Chromophobia", "work_id": 66101, "role": "production company", "role_id": 941, "is_primary": true}], "also_known_as": "", "date_of_birth": null, "date_of_death": null, "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": null, "external_links": [], "uuid": "971b2186-0601-4347-8190-ef8a78ab4a4c", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "10563", "external_references": [], "date_modified": "2025-03-05T12:16:53.711651+11:00"}]}