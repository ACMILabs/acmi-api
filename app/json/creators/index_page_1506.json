iography": "Wanda Jakubowska (10 November 1907 – 25 February 1998) was a Polish film director. Although she directed as many as 15 films over 50 years, Jakubowska is best known for her work on the Holocaust. Her 1948 film The Last Stage was an early and influential depiction of concentration camps. It was filmed on location at Auschwitz, where Jakubowska had been interned.Jakubowska was an ardent Communist whose films were often heavily politicized.: 135-145 ", "biography_author": "Wikidata", "date_of_biography": "2022-05-19T13:21:11.466038+10:00", "external_links": [{"id": 3277, "uri": "https://en.wikipedia.org/wiki/Wanda_Jakubowska"}], "uuid": "61ffa5aa-78c6-4d41-b720-9904e65da0de", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "30271", "external_references": [{"id": 13864, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q437696"}, {"id": 13865, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "273708"}, {"id": 13866, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "no99047892"}, {"id": 13867, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-no99047892"}], "date_modified": "2023-09-13T12:33:14.382216+10:00"}, {"id": 33798, "name": "Caldix Films", "roles_in_work": [{"id": 2074464, "title": "A Soldier's story [DVD]", "work_id": 92372, "role": "production company", "role_id": 941, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": "2023-05-09T11:38:50.723093+10:00", "external_links": [], "uuid": "968dd8f3-eb95-4e55-a783-ba9da8b799f4", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "6196", "external_references": [{"id": 36575, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q121315426"}], "date_modified": "2023-09-05T18:17:17.391150+10:00"}, {"id": 