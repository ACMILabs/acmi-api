_id": 941, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": "2023-05-09T19:03:10.434422+10:00", "external_links": [], "uuid": "30efc2d4-813d-40c5-a79f-f37bd38f6e06", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "7227", "external_references": [{"id": 41116, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q121270793"}], "date_modified": "2023-09-05T18:47:24.114734+10:00"}, {"id": 27472, "name": "Denys Arcand", "roles_in_work": [{"id": 2343289, "title": "The Decline of the American empire = Le Declin de l'empire Americain", "work_id": 93518, "role": "director", "role_id": 938, "is_primary": true}, {"id": 1989885, "title": "Jesus of Montreal", "work_id": 85482, "role": "director", "role_id": 938, "is_primary": true}, {"id": 1997856, "title": "Love and human remains", "work_id": 93507, "role": "director", "role_id": 938, "is_primary": true}], "also_known_as": "", "date_of_birth": "1941-06-25", "date_of_death": null, "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [{"id": 1, "name": "English", "slug": "english"}, {"id": 4, "name": "French", "slug": "french"}], "places_of_operation": [{"id": 36, "name": "Canada", "slug": "canada"}], "biography": "Georges-Henri Denys Arcand  (French: [dəni aʁkɑ̃]; born June 25, 1941) is a French Canadian film director, screenwriter and producer. His film The Barbarian Invasions won the Academy Award for Best Foreign Film in 2004. His films have also been nominated three further times, including two nominations in the same category for The Decline of the American Empire in 1986 and Jesus of Montreal in 1989, becoming the only French-Canadian director in history whose films have received this number of nominations and, subsequently, to have a film win the award. Also for The Barbarian Invasions, he received an Academy Award nomination for Best Original Screenplay, losing to Sofia Coppola for Lost in Translation.During his four decades career, he became the most globally recognized director from Quebec, winning many awards from the Cannes Film Festival, including the Best Screenplay Award, the Jury Prize, and many other prestigious awards worldwide. He won three César Awards in 2004 for The Barbarian Invasions: Best Director, Best Original Screenplay and Best Film, being the only Canadian director to have accomplished this.\nArcand has directed three Canadian films that have received an Academy Award nomination for Best Foreign Film and three films in the Toronto International Film Festival's 2004 list of the top 10 Canadian films of all time.", "biography_author": "Wikidata", "date_of_biography": "2022-05-19T11:17:13.831557+10:00", "external_links": [{"id": 1929, "uri": "https://en.wikipedia.org/wiki/Denys_Arcand"}], "uuid": "8d490570-a2ac-4e48-9f9a-5bc0cb95ee79", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "18019", "external_references": [{"id": 8362, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q363231"}, {"id": 8363, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "51220"}, {"id": 8364, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "n87828438"}, {"id": 8365, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-no2014167834"}], "date_modified": "2023-09-13T12:29:04.485266+10:00"}, {"id": 27470, "name": "Roger Frappier", "roles_in_work": [{"id": 1989883, "title": "Jesus of Montreal", "work_id": 85482, "role": "co-producer", "role_id": 915, "is_primary": true}, {"id": 2343288, "title": "The Decline of the American empire = Le Declin de l'empire Americain", "work_id": 93518, "role": "co-producer", "role_id": 915, "is_primary": true}, {"id": 1995839, "title": "2 Seconds = 2 secondes", "work_id": 92345, "role": "producer", "role_id": 1089, "is_primary": true}