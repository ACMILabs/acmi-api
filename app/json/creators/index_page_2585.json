2"}, {"id": 12827, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "40183119"}, {"id": 12828, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "n50046564"}, {"id": 12829, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-n50046564"}], "date_modified": "2025-03-06T23:40:09.175522+11:00"}, {"id": 12839, "name": "Janet Heyer", "roles_in_work": [{"id": 2678033, "title": "The Back of Beyond", "work_id": 65191, "role": "writer", "role_id": 939, "is_primary": true}], "also_known_as": "", "date_of_birth": "1916-09-14", "date_of_death": "2001-06-19", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [], "places_of_operation": [], "biography": "John Whitefoord Heyer  (14 September 1916 – 19 June 2001) was an Australian documentary filmmaker, who is often described as the father of Australian documentary film.John Heyer spent the majority of his career producing and/or directing sponsored documentaries, and was active from the 1930s until his death. His most successful film was The Back of Beyond (1954), but many of his films garnered awards at festivals around the world. He was committed to the whole process of filmmaking from the initial research phase to distribution and exhibition. While he was grounded in the British documentary tradition, particularly during his years at the Australian National Film Board working under Ralph Foster and Stanley Hawes, he developed his own style noted for its lyrical quality.\nHeyer was an active participant in the documentary film movement in Australia in the 1940s and 1950s: he was among the first producers employed by the Australian National Film Board, was head of the Shell Film Unit in Australia, and was President of the Sydney Film Society and on the committee which organised the first Sydney Film Festival. He moved to England in 1956 where he continued to make films for Shell, and then through his own company. While he died in England, he maintained contact with Australia throughout his life, producing films in both countries.", "biography_author": "Wikidata", "date_of_biography": "2022-05-19T11:53:42.520957+10:00", "external_links": [{"id": 2329, "uri": "https://en.wikipedia.org/wiki/John_Heyer"}], "uuid": "658b379c-5ab1-4134-8774-a0241365c3ac", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "35332", "external_references": [{"id": 9990, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q15458128"}, {"id": 9991, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "91830253"}, {"id": 9992, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "n87914434"}, {"id": 9993, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-n87914434"}], "date_modified": "2025-03-06T23:40:08.594569+11:00"}, {"id": 12836, "name": "George Luger", "roles_in_work": [{"id": 2768530, "title": "Babyhood", "work_id": 65189, "role": "director", "role_id": 938, "is_primary": true}, {"id": 2759103, "title": "Finding out", "work_id": 67516, "role": "director", "role_id": 938, "is_primary": true}], "also_known_as": "", "date_of_birth": null, "date_of_death": null, "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": null, "external_links": [], "uuid": "2d4de9c4-1a53-4282-9f8b-b6a39f1f4c93", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "19635", "external_references": [], "date_modified": "2025-03-14T18:10:17.351439+11:00"}, {"id": 12835, "name": "Eileen Molony", "roles_in_work": [{"id": 2223473, "title": "Expanding classroom: Elizabethan village", "work_id": 96402, "role": "co-director", "role_id": 959, "is_primary": true}, {"id": 2759098, "title": "Maths is a monster", "work_id": 70201, "role": "producer", "role_id": 1089, "is_primary": true}, {"id": 2759095, "title": "The Changeover", "work_id": 65948, "role": "producer", "role_id": 1089, "is_p