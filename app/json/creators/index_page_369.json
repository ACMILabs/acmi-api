{"count": 28682, "next": "https://api.acmi.net.au/creators/?page=370", "previous": "https://api.acmi.net.au/creators/?page=368", "results": [{"id": 81913, "name": "Guo Jian", "roles_in_work": [{"id": 2711556, "title": "The Day Before I Went Away", "work_id": 114189, "role": "producer/director", "role_id": 31, "is_primary": true}], "also_known_as": "", "date_of_birth": "1963", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "Born 1963 Guizhou, China; lives and works in Sydney.\nGuo Jian entered the People's Liberation Army in 1979 as a squad leader and army artist. After retiring he worked as a propaganda artist in a government transportation company. In 1985 he began studying traditional Chinese art at the Central Minorities Institute, Beijing, and graduated in 1989 after the Tiananmen Square massacre. As punishment for his involvement in the hunger strike, he was sent to work in a domestic goods factory. Rejecting this, he began working independently amongst the Yuan Ming Yuan community of artists, immigrating to Australia in 1992. He has held six solo exhibitions and numerous group exhibitions. He is represented by Ray Hughes Gallery, Sydney.", "biography_author": null, "date_of_biography": "2025-03-11T23:55:13.839119+11:00", "external_links": [], "uuid": "94fbae69-d378-429d-a102-e055deb3bbe7", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "2046", "external_references": [{"id": 52183, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q121360810"}], "date_modified": "2025-03-11T23:55:13.839332+11:00"}, {"id": 81912, "name": "Tobias Grime", "roles_in_work": [{"id": 2711529, "title": "Godspeed Verticals", "work_id": 114182, "role": "composer", "role_id": 538, "is_primary": false}], "also_known_as": "", "date_of_birth": null, "date_of_death": null, "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": null, "e