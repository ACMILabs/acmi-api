7, "name": "Pietro Germi", "roles_in_work": [{"id": 2084460, "title": "Alfredo Alfredo", "work_id": 86129, "role": "director", "role_id": 938, "is_primary": true}], "also_known_as": "", "date_of_birth": "1914-09-14", "date_of_death": "1974-12-05", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [{"id": 6, "name": "Italian", "slug": "italian"}], "places_of_operation": [{"id": 19, "name": "Italy", "slug": "italy"}], "biography": "Pietro Germi (Italian pronunciation: [ˈpjɛːtro ˈdʒɛrmi]; 14 September 1914 – 5 December 1974) was an Italian film director, screenwriter, and actor, noted for his development of the neorealist and commedia all'Italiana genres. \nHis 1961 film Divorce Italian Style earned him a Best Original Screenplay Oscar and a Best Director nomination at the 35th Academy Awards. Seven of his films competed at the Cannes Film Festival, with his 1966 comedy The Birds, the Bees and the Italians winning the Palme d'Or.", "biography_author": "Wikidata", "date_of_biography": "2022-05-19T12:45:24.118901+10:00", "external_links": [{"id": 2890, "uri": "https://en.wikipedia.org/wiki/Pietro_Germi"}], "uuid": "1515b09c-7faa-4492-b0dd-3bc672ad40b4", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "26963", "external_references": [{"id": 12290, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q53006"}, {"id": 12291, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "34659494"}, {"id": 12292, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "n88261400"}, {"id": 12293, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-n88261400"}], "date_modified": "2023-09-13T12:32:03.725248+10:00"}]}