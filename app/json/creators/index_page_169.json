me": "Yarraville West Primary School", "roles_in_work": [{"id": 2718348, "title": "Buzz Off", "work_id": 117243, "role": "creator", "role_id": 968, "is_primary": true}, {"id": 2719440, "title": "George and his groaning mouth", "work_id": 117681, "role": "creator", "role_id": 968, "is_primary": true}, {"id": 2304700, "title": "Max's Farm", "work_id": 117437, "role": "co-producers/directors", "role_id": 628, "is_primary": true}, {"id": 2304696, "title": "Max's Farm", "work_id": 117437, "role": "school", "role_id": 619, "is_primary": false}, {"id": 2718345, "title": "Buzz Off", "work_id": 117243, "role": "school", "role_id": 619, "is_primary": false}, {"id": 2718455, "title": "Sunday's dog", "work_id": 117316, "role": "school", "role_id": 619, "is_primary": false}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": "2023-05-09T19:58:09.813269+10:00", "external_links": [], "uuid": "586a65b9-41f7-409b-a447-a0f53129545b", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "35878", "external_references": [], "date_modified": "2025-03-12T07:05:18.644320+11:00"}, {"id": 83908, "name": "Ashley Miller", "roles_in_work": [{"id": 2076527, "title": "A Trip to Mars", "work_id": 117242, "role": "director", "role_id": 938, "is_primary": true}], "also_known_as": "", "date_of_birth": "1867-08-11", "date_of_death": "1949-11-19", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [], "places_of_operation": [{"id": 1, "name": "United States of America", "slug": "united-states-of-america"}], "biography": "Ashley Miller (August 11, 1877 – November 19, 1949) was an American director, screenwriter, playwright, and actor. He directed 133 films between 1909 and 1923.Miller was born in Cincinnati and attended schools in Detroit, Michigan.Miller's stage debut came in September 1904 when he portrayed Francois in a production of Richelieu. He went on to act with stock theater companies in Boston, Chicago, New York, and Philadelphia. Plays in which he performed include Prince Otto, Romeo and Juliet, A Midsummer Night's Dream, My Lady Peggy Goes to Town, and The Parisian Model. His roles in the latter two productions were singing parts.Miller formed a troupe that presented plays in New York City's schools and settlement houses. He also worked as a director of silent films for the Edison Biograph Studio.In 1933, Miller became executive secretary of the State Relief Fund, an organization created by \"prominent actors, producers and playwrights\".Miller was married to actress Ethel Browning from 1899 until his death in 1949, and they had a son, Ashley. He died on November 19, 1949, in New York.", "biography_author": "Wikidata", "date_of_biography": "2023-08-01T14:07:30.263186+10:00", "external_links": [{"id": 1689, "uri": "https://en.wikipedia.org/wiki/Ashley_Miller_(director)"}], "uuid": "0ae8db93-4b97-4de9-8bac-59db5cb8efc9", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "35871", "external_references": [{"id": 7365, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q3625017"}, {"id": 7366, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "33446871"}, {"id": 7367, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "n85262690"}, {"id": 7368, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-n85262690"}], "date_modified": "2023-09-06T10:17:20.367506+10:00"}]}