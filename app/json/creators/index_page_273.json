{"count": 28681, "next": "https://api.acmi.net.au/creators/?page=274", "previous": "https://api.acmi.net.au/creators/?page=272", "results": [{"id": 82873, "name": "Xu Huanshan", "roles_in_work": [{"id": 2234626, "title": "Raftsmen = Fazi ke", "work_id": 115848, "role": "cast", "role_id": 33, "is_primary": false}, {"id": 2651400, "title": "The Acting mayor = Dai li shi zhang", "work_id": 115836, "role": "cast", "role_id": 33, "is_primary": false}], "also_known_as": "", "date_of_birth": "1937-07-13", "date_of_death": "", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [], "places_of_operation": [{"id": 290, "name": "People's Republic of China", "slug": "peoples-republic-of-china"}], "biography": "Xu Huanshan (born 13 July 1937) is a Chinese actor and occasional film director. Xu was enrolled in the Beijing Film Academy in 1956. A year later, he was labelled as a \"rightist\" and was sent for \"re-education through labour\" under the Communist government's Anti-Rightist Movement. In 1966, he was sent to Xinjiang to perform hard labour. He returned to Beijing in 1979 and started his acting career. In 1980, he joined the Xi'an Film Production Company (西安电影制片厂) as an actor, and six years later he became a film director. He is best known for playing supporting roles in many television series.", "biography_author": "Wikidata", "date_of_biography": "2023-09-06T02:21:35.172297+10:00", "external_links": [{"id": 6259, "uri": "https://en.wikipedia.org/wiki/Xu_Huanshan"}], "uuid": "ee675f1d-88fd-4160-8177-d16cc1ef01a7", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "36305", "external_references": [{"id": 51180, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q8045101"}, {"id": 56094, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "95071115"}], "date_modified": "2025-03-05T14:29:35.851529+11:00"}, {"id": 82872, "name": "Su Hongwen", "roles_in_work": [{"id": 2651398, "title": "The Acting mayor =