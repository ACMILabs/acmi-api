rimary": true}, {"id": 2614978, "title": "The Beguiled", "work_id": 84610, "role": "producer/director", "role_id": 31, "is_primary": true}], "also_known_as": "", "date_of_birth": "1912-10-26", "date_of_death": "1991-04-20", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [{"id": 1, "name": "English", "slug": "english"}], "places_of_operation": [{"id": 1, "name": "United States of America", "slug": "united-states-of-america"}], "biography": "Donald Siegel (; October 26, 1912 – April 20, 1991) was an American film and television director and producer.\nSiegel was described by The New York Times as \"a director of tough, cynical and forthright action-adventure films whose taut plots centered on individualistic loners\". He directed the science fiction horror film Invasion of the Body Snatchers (1956), as well as five films with Clint Eastwood, including the police thriller Dirty Harry (1971) and the prison drama Escape from Alcatraz (1979). He also directed John Wayne's final film, the Western The Shootist (1976).", "biography_author": "Wikidata", "date_of_biography": "2022-05-19T11:18:31.443311+10:00", "external_links": [{"id": 1942, "uri": "https://en.wikipedia.org/wiki/Don_Siegel"}], "uuid": "31807278-c8e5-4cc0-bab0-a267ef5f5c47", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "18257", "external_references": [{"id": 8420, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q358322"}, {"id": 8421, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "24816488"}, {"id": 8422, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "n88245204"}, {"id": 8423, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-n88245204"}], "date_modified": "2025-02-26T20:17:31.021717+11:00"}, {"id": 23466, "name": "Tarak Ben Ammar", "roles_in_work": [{"id": 2238246, "title": "Femme fatale [DVD]", "work_id": 94319, "role": "co-producer", "role_id": 915, "is_primary": true}, {"id": 1985325, "title": "La Traviata", "work_id": 81221, "role": "producer", "role_id": 1089, "is_primary": true}, {"id": 3104751, "title": "Les Cavaliers de L'orage = the Horsemen of the Storm", "work_id": 116065, "role": "producer", "role_id": 1089, "is_primary": true}], "also_known_as": "", "date_of_birth": "12 JUN 1949", "date_of_death": "", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [], "places_of_operation": [{"id": 325, "name": "French protectorate of Tunisia", "slug": "french-protectorate-of-tunisia"}], "biography": "Tarak Ben Ammar (Arabic: طارق بن عمّار; born June 12, 1949) is a Tunisian-French film producer and distributor; the owner of French production and distribution company Quinta Communications. He is famous for his interest in artistic movies, especially when they are related to Mediterranean culture or require North African locations. His producing credits include the Franco Zeffirelli film adaptation of La Traviata and Claude Chabrol's Death Rite. On 19 May 2010, he announced a \"strategic relationship\" with the Weinstein Company.Ben Ammar became well-known in France, at the beginning of 2004, when he decided to distribute The Passion of The Christ after everybody else declined. He appeared on television talk shows, defending the movie. He is also known as the advisor of international investor Prince Al Waleed Bin Talal Bin Abdul Aziz, and French businessman Vincent Bolloré.He was formerly a manager of Michael Jackson's HIStory World Tour. Source: Wikidata; 01/08/2023", "biography_author": null, "date_of_biography": "2025-05-22T22:46:59.625861+10:00", "external_links": [{"id": 5241, "uri": "https://en.wikipedia.org/wiki/Tarak_Ben_Ammar"}], "uuid": "a3befdb4-40e5-4cf0-9824-2eabac05a4c0", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "29492", "external_references": [{"id": 25905, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q962765"}, {"id": 31723, "source": {"na