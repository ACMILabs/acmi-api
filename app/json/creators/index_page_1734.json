5715, "role": "co-director", "role_id": 959, "is_primary": true}, {"id": 2171726, "title": "Monica's seaside adventures", "work_id": 85715, "role": "producer", "role_id": 1089, "is_primary": true}], "also_known_as": "", "date_of_birth": null, "date_of_death": "", "genders": [{"id": 5, "name": "Female", "slug": "female"}], "languages": [], "places_of_operation": [{"id": 3, "name": "Australia", "slug": "australia"}], "biography": "Monica Maria Trapaga (born 1965) is an Australian entertainment presenter, jazz singer, and writer. She was a presenter on the Australian children's series, Play School, from 1990 to 1998; and had provided the vocals to the theme of Bananas in Pyjamas from 1992. She is the youngest sister of Ignatius Jones, an events director, journalist, actor and shock rocker. Trápaga appeared on Better Homes and Gardens from 1997 to 2003, in decoration-related segments. While on Play School, she started recording children's music albums as well as jazz ones. She was a member of various groups: Pardon Me Boys, Monica and the Moochers, and Monica Trapaga and the Bachelor Pad. Since the early 2000s, she has owned stores in Summer Hill and Newtown.", "biography_author": "Wikidata", "date_of_biography": "2023-09-05T23:20:07.213068+10:00", "external_links": [{"id": 6047, "uri": "https://en.wikipedia.org/wiki/Monica_Trapaga"}], "uuid": "c0322c53-c4af-4de3-9b70-b062849a3e38", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "25501", "external_references": [{"id": 39388, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q16832560"}], "date_modified": "2023-09-05T23:20:12.329740+10:00"}, {"id": 27775, "name": "Monica and the Moochers", "roles_in_work": [{"id": 2171723, "title": "Monica's seaside adventures", "work_id": 85715, "role": "production company", "role_id": 941, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biograph