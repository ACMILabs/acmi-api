oper", "role_id": 658, "is_primary": true}, {"id": 3110074, "title": "Celeste (logo)", "work_id": 125503, "role": "developer", "role_id": 658, "is_primary": true}, {"id": 3110075, "title": "Celeste (Character Art - Madeline)", "work_id": 125500, "role": "developer", "role_id": 658, "is_primary": true}], "also_known_as": "", "date_of_birth": "1988", "date_of_death": null, "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": null, "external_links": [], "uuid": "c9c6b5e4-5f26-431d-946b-bc1f26202cb2", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "41711", "external_references": [], "date_modified": "2025-12-02T14:36:44.435521+11:00"}, {"id": 89083, "name": "Timothy Charles-Koch", "roles_in_work": [{"id": 3109018, "title": "Salix8 Sunset", "work_id": 125409, "role": "games developer/developer", "role_id": 1092, "is_primary": false}], "also_known_as": "", "date_of_birth": null, "date_of_death": null, "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": null, "external_links": [], "uuid": "e6d464db-9d16-4309-94d6-857f0ffa0ce8", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "41631", "external_references": [], "date_modified": "2025-10-27T15:30:34.727269+11:00"}, {"id": 89082, "name": "Yarn Spinner", "roles_in_work": [{"id": 3109016, "title": "Hint Line '93", "work_id": 125408, "role": "games studio", "role_id": 1090, "is_primary": false}], "also_known_as": "", "date_of_birth": null, "date_of_death": null, "genders": [], "languages": [], "places_of_operation": [], "biography": "Yarn Spinner is a spinoff company from award-winning game development studio, Secret Lab.\n\nSecret Lab originally built Yarn Spinner while working on BAFTA- and IGF-winning hit, Night in the Woods. The Yarn Spinner company was funded by Secret Lab, and spun-off to allow Secret Lab to focus on its core activities (making games), and Yarn Spinner to focus on its (making tools). The two companies shared some directors and shareholders.\n\nYarn Spinner is based in Hobart, Tasmania, Australia, and is led by Dr Jon Manning, Dr Tim Nugent, and Dr Paris Buttfield-Addison.\n\nThe Yarn Spinner team is happy to consult on narrative, Yarn Spinner technologies, or integrate with your team to implement features, narrative systems, and Yarn Spinner.\nSource: Yarn Spinner website, accessed 7 October 2025, <https://www.yarnspinner.dev/company>.", "biography_author": null, "date_of_biography": "2025-10-27T15:30:27.895016+11:00", "external_links": [], "uuid": "11960f4b-37b2-477a-906a-0705b755ac6f", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "41668", "external_references": [], "date_modified": "2025-10-27T15:30:27.895253+11:00"}, {"id": 89081, "name": "Secret Lab", "roles_in_work": [{"id": 3109015, "title": "Hint Line '93", "work_id": 125408, "role": "games studio", "role_id": 1090, "is_primary": false}], "also_known_as": "", "date_of_birth": null, "date_of_death": null, "genders": [], "languages": [], "places_of_operation": [], "biography": "Secret Lab is a games and creative technology studio located in Hobart, Australia, founded by Dr Paris Buttfield-Addison and Dr Jon Manning.\nWe’ve been enthusiastically building games, narrative experiences, and technology for culture, history, arts, storytelling, and beyond since 2008.\nWe’re the proud creators of Yarn Spinner, the interactive storytelling tool, and are currently working on the BAFTA- and IGF-winning Night in the Woods, as well as the Screen Tasmania-funded I Feel Fine.\nWe primarily work on our own creations, but if you’re lucky you can hire us to build games, interactive experiences, fancy apps, or to add features to, or support your integration of Yarn Spinner.\nSource: Secret Lab website, accessed 7 October 2025, <https://secretlab.games/>.", "biography_author": null, "date_of_biography": "2025-10-27T15:30:27.177599+11:00", "external_links": [], "uuid": "f85e7746-5fc6-4a11-b893-fab534ca2423", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "41667", "external_references": [], "date_modified": "2025-10-27T15:30:27.177811+11:00"}, {"id": 89080, "name": "Paris Buttfield-Addison", "roles_in_work": [{"id": 3109014, "title": "Hint Line '93", "work_id": 125408, "role": "games developer/developer", "role_id": 1092, "is_primary": false}], "also_known_as": "", "date_of_birth": null, "date_of_death": null, "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": null, "external_links": [], "uuid": "5c967bbd-337a-4005-80ab-9401dd50d750", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "41630", "external_references": [], "date_modified": "2025-10-27T15:30:26.473842+11:00"}, {"id": 89079, "name": "Apartment 809", "roles_in_work": [{"id": 3109012, "title": "ACMI Egg", "work_id": 125407, "role": "games studio", "role_id": 1090, "is_primary": false}], "also_known_as": "", "date_of_birth": null, "date_of_death": null, "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": null, "external_links": [], "uuid": "87ca14bf-6f19-4d8a-a599-de1163ef7ef1", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "41666", "external_references": [], "date_modified": "2025-10-27T15:30:15.911542+11:00"}, {"id": 89078, "name": "Katsumi Yoshida", "roles_in_work": [{"id": 3109011, "title": "ACMI Egg", "work_id": 125407, "role": "character designer", "role_id": 945, "is_primary": false}], "also_known_as": "", "date_of_birth": null, "date_of_death": null, "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": null, "external_links": [], "uuid": "84fae111-081e-45a8-bc50-bbfd9bc13346", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "41665"