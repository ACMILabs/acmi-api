stival buildings", "work_id": 88388, "role": "production company", "role_id": 941, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": "2023-05-09T13:09:35.982953+10:00", "external_links": [], "uuid": "6ad2191c-6c14-4f87-9e69-593754565fa2", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "10341", "external_references": [{"id": 40246, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q121271500"}], "date_modified": "2023-09-05T22:53:33.101563+10:00"}, {"id": 30495, "name": "Redeemable Features", "roles_in_work": [{"id": 2353544, "title": "The Hairy bird", "work_id": 95105, "role": "production company", "role_id": 941, "is_primary": true}, {"id": 1992754, "title": "Lulu on the bridge", "work_id": 88386, "role": "production company", "role_id": 941, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": "2023-05-09T20:00:28.974900+10:00", "external_links": [], "uuid": "7d65b270-5154-4588-a8bc-565641d4c292", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "11915", "external_references": [{"id": 40208, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q121315569"}], "date_modified": "2023-09-06T00:24:26.619283+10:00"}, {"id": 30494, "name": "Tommy O'Haver", "roles_in_work": [{"id": 2116153, "title": "Billy's Hollywood screen kiss", "work_id": 88385, "role": "director", "role_id": 938, "is_primary": true}], "also_known_as": "", "date_of_birth": "1968-10-24", "date_of_death": null, "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [{"id": 1, "name": "English", "slug": "english"}], "places_of_operation": [{"id": 1, "name": "United States of America", "slug": "united-states-of-america"}], "biography": "Tommy O'Haver (born October 24, 1968, Indianapolis, Indiana) is an American film director and screenwriter.\nHe grew up in Carmel, Indiana, a suburb of Indianapolis. He graduated from Carmel High School and matriculated at Indiana University with a joint degree in Journalism and Comparative Literature. In the mid-1990s, he attended the MFA Film program at the University of Southern California School of Cinematic Arts. While there, he directed shorts that appeared at major festivals, including Sundance and The New York Film Festival.\nBilly's Hollywood Screen Kiss, featuring Sean Hayes, was O'Haver's directorial debut. Billy's Hollywood Screen Kiss played in competition at the 1998 Sundance Film Festival and screened at the Helsinki International Film Festival. His follow-up film Get Over It featured Kirsten Dunst, Ben Foster, Mila Kunis and Zoe Saldana in a teen comedy about a school theater production. O'Haver's third film, Ella Enchanted, starred Anne Hathaway. Catherine Keener, Elliot Page and James Franco star in An American Crime, which premiered at Sundance in 2007, a film based on a true story of Gertrude Baniszewski, an Indiana woman charged in 1965 with the murder of Sylvia Likens. The initial reaction at Sundance was mixed, but the film garnered critical praise. O'Haver and his writing partner, Irene Turner, were nominated for a Writer's Guild Award for the film as well.\nIn June 2013, he directed the music video \"Rollin'\" for MiBBs. On April 2, 2015, the seventh episode of The Late Late Show with James Corden was broadcast from O'Haver's house.In 2017, O'Haver's fifth film, The Most Hated Woman in America, was released; it starred  Melissa Leo as Madalyn Murray O'Hair, the founder of American Atheists.", "biography_author": "Wikidata", "date_of_biography": "2022-05-19T13:16:31.331980+10:00", "external_links": [{"id": 3226, "uri": "https://en.wikipedia.org/wiki/Tommy_O%27Haver"}], "uuid": "8ab97c52-1c51-4e43-a803-5e