, "is_primary": true}], "also_known_as": "", "date_of_birth": "1891", "date_of_death": "Circa 1910", "genders": [], "languages": [], "places_of_operation": [], "biography": "The Limelight Department was one of the world's first film studios, beginning in 1898, operated by The Salvation Army in Melbourne, Australia. The Limelight Department produced evangelistic material for use by the Salvation Army, including lantern slides as early as 1891, as well as private and government contracts. In its 19 years of operation, the Limelight Department produced about 300 films of various lengths, making it one of largest film producers of its time.", "biography_author": null, "date_of_biography": "2025-03-19T22:40:06.844243+11:00", "external_links": [], "uuid": "6493cf72-76e9-498a-88c3-ca7b343de575", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "34475", "external_references": [], "date_modified": "2025-03-19T22:40:06.844480+11:00"}, {"id": 71259, "name": "Enki Bilal", "roles_in_work": [{"id": 2307727, "title": "Mémoires d'outre-espace, Histoires courtes 1974–1977", "work_id": 99507, "role": "author", "role_id": 943, "is_primary": true}], "also_known_as": "", "date_of_birth": "1951-10-07", "date_of_death": "", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [{"id": 4, "name": "French", "slug": "french"}], "places_of_operation": [{"id": 17, "name": "France", "slug": "france"}], "biography": "Enki Bilal (born Enes Bilal; born 7 October 1951) is a French comic book creator, comics artist and film director.", "biography_author": "Wikidata", "date_of_biography": "2023-09-05T19:32:50.772848+10:00", "external_links": [{"id": 5800, "uri": "https://en.wikipedia.org/wiki/Enki_Bilal"}], "uuid": "f9dae369-e451-42a1-aa8e-fc6ee08ecd83", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "39429", "external_references": [{"id": 43005, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q333668"}, {"id": 54387, 