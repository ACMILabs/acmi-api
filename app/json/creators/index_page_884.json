_operation": [], "biography": "", "biography_author": null, "date_of_biography": null, "external_links": [], "uuid": "89f98017-767c-4ab3-a8f1-392ed7ecc2f5", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": null, "external_references": [{"id": 38999, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q121036502"}], "date_modified": "2023-09-05T18:38:39.652160+10:00"}, {"id": 76735, "name": "Cliff Reid", "roles_in_work": [{"id": 2356119, "title": "The Informer", "work_id": 80838, "role": "producer", "role_id": 1089, "is_primary": true}, {"id": 2097694, "title": "Annie Oakley", "work_id": 81309, "role": "producer", "role_id": 1089, "is_primary": true}], "also_known_as": "", "date_of_birth": "1891-09-07", "date_of_death": "1959-08-22", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [], "places_of_operation": [{"id": 1, "name": "United States of America", "slug": "united-states-of-america"}], "biography": "Cliff Reid (September 7, 1891 – August 22, 1959), also known as George Clifford Reid, was an American film producer and film production studio founder during the 1930s and 1940s. In addition he also directed film shorts, and was the assistant director on several feature films.", "biography_author": "Wikidata", "date_of_biography": "2023-08-01T14:29:32.247828+10:00", "external_links": [{"id": 3793, "uri": "https://en.wikipedia.org/wiki/Cliff_Reid"}], "uuid": "761fbf73-f9ef-4b78-8a4c-40cbfb3d5623", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "17118", "external_references": [{"id": 26810, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q20828223"}, {"id": 27912, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "117916737"}, {"id": 27913, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "n85273981"}, {"id": 27914, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-n85273981"}], "date_modified": "2023-09-05T18:42:27.973013+10:00"}, {"id": 76734, "name": "Maximilian Schell", "roles_in_work": [{"id": 2415665, "title": "Marlene", "work_id": 80834, "role": "director", "role_id": 938, "is_primary": true}, {"id": 1986919, "title": "Judgment at Nuremberg", "work_id": 83107, "role": "cast", "role_id": 33, "is_primary": false}], "also_known_as": "", "date_of_birth": "1930-12-08", "date_of_death": "2014-02-01", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [{"id": 5, "name": "German", "slug": "german"}], "places_of_operation": [{"id": 26, "name": "Switzerland", "slug": "switzerland"}], "biography": "Maximilian Schell (8 December 1930 – 1 February 2014) was an Austrian-born Swiss actor, who also wrote, directed and produced some of his own films. He won the Academy Award for Best Actor for the 1961 American film Judgment at Nuremberg, his second acting role in Hollywood. Born in Austria, his parents were involved in the arts and he grew up surrounded by performance and literature. While he was still a child, his family fled to Switzerland in 1938 when Austria was annexed by Nazi Germany, and they settled in Zurich. After World War II ended, Schell took up acting and directing full-time. He appeared in numerous German films, often anti-war, before moving to Hollywood.\nFluent in both English and German, Schell earned top billing in a number of Nazi-era themed films. Two earned him Oscar nominations: The Man in the Glass Booth (1975), for a character with two identities, and Julia (1977), portraying a member of a group resisting Nazism.\nHis range of portrayals included personalities as diverse as Venezuelan leader Simón Bolívar, Russian emperor Peter the Great, and physicist Albert Einstein. For his role as Vladimir Lenin in the television film Stalin (1992) he won the Golden Globe Award. Schell also performed in a number of stage plays, including a celebrated performance as Prince Hamlet.Schell was an accomplished pianist and conductor, performing with Claudio Abbado and Leonard Bernstein, and with orchestras in Berlin and Vienna. His elder sister was the internationally noted actress Maria Schell; he produced the documentary tribute My Sister Maria in 2002.\n\n", "biography_author": "Wikidata", "date_of_biography": "2023-08-15T11:50:52.788106+10:00", "external_links": [{"id": 2685, "uri": "https://en.wikipedia.org/wiki/Maximilian_Schell"}], "uuid": "64c4ac07-0a11-456f-94d7-227e22156070", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "24888", "external_references": [{"id": 11459, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q153018"}, {"id": 11460, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "19866935"}, {"id": 11461, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "n86025468"}, {"id": 11462, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-n86025468"}], "date_modified": "2023-09-05T22:58:11.620454+10:00"}, {"id": 76733, "name": "Matthew Flanagan", "roles_in_work": [{"id": 2356352, "title": "The Irish in Australia: Echo of a Distant Drum", "work_id": 80832, "role": "co-director", "role_id": 959, "is_primary": true}, {"id": 906307, "title": "Heartlands : taking control", "work_id": 86992, "role": "co-producer", "role_id": 915, "is_primary": true}, {"id": 906308, "title": "Heartlands : taking control", "work_id": 86992, "role": "director", "role_id": 938, "is_primary": true}, {"id": 1805088, "title": "Heartlands with Dean Graetz : arid", "work_id": 86989, "role": "producer", "role_id": 1089, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": "2023-05-09T20:04:29.129295+10:00", "external_links": [], "uuid": "14685ab8-71e1-4d11-96e4-38d9f5aa9188", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "24801", "ex