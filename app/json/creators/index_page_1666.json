peration": [], "biography": "", "biography_author": null, "date_of_biography": "2023-05-09T12:29:25.487780+10:00", "external_links": [], "uuid": "9ce979dc-8ab7-4a02-b336-51b30f5b7e51", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "11840", "external_references": [{"id": 35877, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q121271111"}], "date_modified": "2023-09-06T00:18:34.261124+10:00"}, {"id": 29401, "name": "Rudolf Nureyev", "roles_in_work": [{"id": 2198526, "title": "Don Quixote [Nureyev]", "work_id": 87405, "role": "co-director", "role_id": 959, "is_primary": true}, {"id": 917866, "title": "Giselle", "work_id": 95362, "role": "co-director", "role_id": 959, "is_primary": true}, {"id": 2253563, "title": "Romeo and Juliet (Prokofiev)", "work_id": 95326, "role": "director", "role_id": 938, "is_primary": true}], "also_known_as": "", "date_of_birth": "1938-03-17", "date_of_death": "1993-01-06", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [{"id": 3, "name": "Russian", "slug": "russian"}, {"id": 99, "name": "Tatar", "slug": "tatar"}], "places_of_operation": [{"id": 180, "name": "Soviet Union", "slug": "soviet-union"}], "biography": "Rudolf Khametovich Nureyev ( NURE-ee-ef, nyuurr-AY-ef; Tatar/Bashkir: Rudolf Xämit uğlı Nuriev, Рудольф Хәмит улы Нуриев; Russian: Рудольф Хаметович Нуреев, IPA: [rʊˈdolʲf xɐˈmʲetəvʲɪtɕ nʊˈrʲejɪf]; 17 March 1938 – 6 January 1993) was a Soviet-born ballet dancer and choreographer. Nureyev is regarded by some as the greatest male ballet dancer of his generation.Nureyev was born on a Trans-Siberian train near Irkutsk, Siberia, Soviet Union, to a Tatar family. He began his early career with the company that in the Soviet era was called the Kirov Ballet (now called by its original name, the Mariinsky Ballet) in Leningrad. He defected from the Soviet Union to the West in 1961, despite KGB efforts to stop him. This was the first defection of a Soviet artist during the Cold War, and it created an international sensation. He went on to dance with The Royal Ballet in London and from 1983 to 1989 served as director of the Paris Opera Ballet. Nureyev was also a choreographer serving as the chief choreographer of the Paris Opera Ballet. He produced his own interpretations of numerous classical works, including Swan Lake, Giselle and La Bayadère.", "biography_author": "Wikidata", "date_of_biography": "2023-08-01T16:56:34.227084+10:00", "external_links": [{"id": 5088, "uri": "https://en.wikipedia.org/wiki/Rudolf_Nureyev"}], "uuid": "0ddbb50c-daf1-4977-878f-f63ef04b3771", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "28330", "external_references": [{"id": 26328, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q84217"}, {"id": 31334, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "148483"}, {"id": 31335, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "n79063858"}, {"id": 31336, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-n79063858"}], "date_modified": "2023-09-06T00:58:16.225290+10:00"}, {"id": 29400, "name": "John L. Hargreaves", "roles_in_work": [{"id": 2198525, "title": "Don Quixote [Nureyev]", "work_id": 87405, "role": "producer", "role_id": 1089, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": "2023-05-09T15:21:53.959114+10:00", "external_links": [], "uuid": "ef87cbd8-dcbd-44e1-a665-874361ed86da", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "22360", "external_references": [{"id": 36146, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q121222579"}], "date_modified": "2023-09-05T21:40:15.004934+10:00"}, {"id": 29399, "name": "International Arts", "roles_in_work": [{"id": 2198519, "title": "Don Quixote [Nur