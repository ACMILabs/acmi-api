t communication and consciousness.\n\nImage credit: Jacquie Manning; 08/08/2023", "biography_author": null, "date_of_biography": "2025-06-23T16:35:02.348710+10:00", "external_links": [], "uuid": "1f2055ae-74f3-41c5-891c-6619ddb9812a", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "39491", "external_references": [], "date_modified": "2025-06-23T16:35:02.348956+10:00"}, {"id": 86156, "name": "Kristen Vinck", "roles_in_work": [], "also_known_as": "", "date_of_birth": null, "date_of_death": null, "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": null, "external_links": [], "uuid": "a9e818b4-5ae7-4ee5-8814-ff0a633d6410", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": null, "external_references": [], "date_modified": "2023-06-14T16:33:30.576250+10:00"}, {"id": 86155, "name": "Sioux", "roles_in_work": [], "also_known_as": "", "date_of_birth": null, "date_of_death": null, "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": null, "external_links": [], "uuid": "043333f7-43ac-4d0e-b6fd-7dc7a31aa98c", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": null, "external_references": [], "date_modified": "2023-06-14T16:33:30.576250+10:00"}, {"id": 86154, "name": "Voodoo", "roles_in_work": [{"id": 3107756, "title": "Cyberthon V: Spectrum 4 - Green", "work_id": 117985, "role": "lighting", "role_id": 447, "is_primary": false}, {"id": 3107729, "title": "Cyberthon V: Spectrum 3 - Yellow", "work_id": 118005, "role": "props", "role_id": 238, "is_primary": false}, {"id": 3107757, "title": "Cyberthon V: Spectrum 4 - Green", "work_id": 117985, "role": "props", "role_id": 238, "is_primary": false}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": "2023-0