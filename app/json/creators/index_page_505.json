l_references": [{"id": 36842, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q121336963"}], "date_modified": "2025-03-17T10:38:30.972529+11:00"}, {"id": 80528, "name": "Catherine Fol", "roles_in_work": [{"id": 917101, "title": "This is not Einstein", "work_id": 95033, "role": "director", "role_id": 938, "is_primary": true}, {"id": 2340519, "title": "The Cosmic link [Widescreen]", "work_id": 93886, "role": "director", "role_id": 938, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": "2023-05-09T19:38:52.848805+10:00", "external_links": [], "uuid": "2eec430f-4266-484e-a5c1-0d6eefc96f2c", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "16594", "external_references": [{"id": 33090, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q121143768"}], "date_modified": "2023-09-05T18:22:38.357867+10:00"}, {"id": 80527, "name": "Joseph McGrath", "roles_in_work": [{"id": 2795119, "title": "Casino royale", "work_id": 93885, "role": "co-director", "role_id": 959, "is_primary": true}], "also_known_as": "", "date_of_birth": "01 JAN 1930", "date_of_death": "", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [{"id": 1, "name": "English", "slug": "english"}], "places_of_operation": [{"id": 10, "name": "United Kingdom", "slug": "united-kingdom"}], "biography": "Joseph McGrath  (born 28 March 1928) is a Scottish film and television director and screenwriter. He was born in Glasgow and studied at Glasgow School of Art in the late 1940s and early 1950s where his energy and talent was admired by his contemporaries.McGrath is best known for his collaborations with The Goon Show stars Peter Sellers and Spike Milligan. He directed the scenes with Sellers and Orson Welles in the multi-director James bond spoof Casino Royale (1967). He also directed Sellers and Spike Milligan in The Magic Christian (1969) and The Great McGonagall (1974).McGrath also worked with director Richard Lester on the Beatles' musical-comedy films A Hard Day's Night (1964) and Help! (1965). In November 1965, McGrath directed the Beatles' first-ever music videos (known at the time as \"promo clips\"), filming the band miming to five of their hit songs, including \"Ticket to Ride\", \"Help!\" and \"Day Tripper\".In the 2004 film The Life and Death of Peter Sellers, Alan Williams plays the unnamed director of Casino Royale, whom Sellers (played by Geoffrey Rush) calls \"Joe\". Source: Wikidata; 01/08/2023", "biography_author": null, "date_of_biography": "2025-03-14T20:30:25.125539+11:00", "external_links": [{"id": 2475, "uri": "https://en.wikipedia.org/wiki/Joseph_McGrath_(film_director)"}], "uuid": "f5228b6e-d654-4bb1-87c9-583a4842d9b3", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "22738", "external_references": [{"id": 10577, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q6285469"}, {"id": 10578, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "120343005"}, {"id": 10579, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "n79042624"}, {"id": 10580, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-n79042624"}], "date_modified": "2025-03-14T20:30:25.125817+11:00"}, {"id": 80526, "name": "John Glen", "roles_in_work": [{"id": 2795091, "title": "For your eyes only (Special edition)", "work_id": 93875, "role": "director", "role_id": 938, "is_primary": true}, {"id": 2795069, "title": "The Living daylights (Special edition)", "work_id": 93872, "role": "director", "role_id": 938, "is_primary": true}, {"id": 2795087, "title": "Licence to kill (Special edition)", "work_id": 93874, "role": "director", "role_id": 938, "is_primary": true}, {"id": 2795101, "title": "Octopussy (Special edition)", "work_id": 93879, "role": "director"