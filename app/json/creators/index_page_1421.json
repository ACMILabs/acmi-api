{"count": 28687, "next": "https://api.acmi.net.au/creators/?page=1422", "previous": "https://api.acmi.net.au/creators/?page=1420", "results": [{"id": 36357, "name": "Patrick Stettner", "roles_in_work": [{"id": 2335231, "title": "The Business of strangers [DVD]", "work_id": 94423, "role": "director", "role_id": 938, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [], "places_of_operation": [{"id": 1, "name": "United States of America", "slug": "united-states-of-america"}], "biography": "Patrick Stettner is an American film director and writer. His first film, Flux, was released in 1996 as a short, and starred Allison Janney in an early role. He went on to direct and write the screenplay for The Business of Strangers in 2001, which earned him a Grand Jury Prize nomination at the Sundance Film Festival of that year and earned lead actress Stockard Channing an AFI nomination for Best Female Actress. In 2006, he then wrote and directed The Night Listener, an adaptation of Armistead Maupin's eponymous semi-autobiographical 2000 novel, which landed less-than-stellar reviews from critics. He has not directed any films since The Night Listener.\nHe is an alumnus of Columbia University School of the Arts' film division.", "biography_author": "Wikidata", "date_of_biography": "2023-08-01T16:28:27.992607+10:00", "external_links": [{"id": 4825, "uri": "https://en.wikipedia.org/wiki/Patrick_Stettner"}], "uuid": "015f8759-ce53-4707-b5b7-b9378f049ba5", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "26152", "external_references": [{"id": 25395, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q7147685"}], "date_modified": "2023-09-05T23:43:50.849275+10:00"}, {"id": 36355, "name": "i5 Films", "roles_in_work": [{"id": 2335219, "title": "The Business of strangers [DVD]", "work_id": 94423, "role": "production company", "role_id": 941, "