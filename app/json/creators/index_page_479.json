, {"id": 4, "name": "French", "slug": "french"}], "places_of_operation": [{"id": 60, "name": "Lebanon", "slug": "lebanon"}], "biography": "Jocelyne Saab (30 April 1948 – 7 January 2019) was a Lebanese journalist and film director. She is recognized as one of the pioneers of Lebanese cinema. A reporter, photographer, scriptwriter, producer, director, artist and founder of the Cultural Resistance International Film Festival of Lebanon, Saab focused on the deprived and disadvantaged – from displaced peoples to exiled fighters, cities at war and a Fourth World without a voice. Her work is grounded in historic violence, and in an awareness of the actions and images required to document, reflect on and counteract it.", "biography_author": "Wikidata", "date_of_biography": "2023-08-01T15:33:07.725665+10:00", "external_links": [{"id": 2394, "uri": "https://en.wikipedia.org/wiki/Jocelyne_Saab"}], "uuid": "ed9387a2-4a6d-4093-a7ce-2ea5050927a4", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "22013", "external_references": [{"id": 10254, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q454431"}, {"id": 10255, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "223783781"}, {"id": 10256, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "no2008016517"}, {"id": 10257, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-no2008016517"}], "date_modified": "2023-09-05T21:29:07.999121+10:00"}, {"id": 80784, "name": "Danielle Smith", "roles_in_work": [{"id": 2330052, "title": "The Beat of distant hearts", "work_id": 94404, "role": "producer/director", "role_id": 31, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": "2023-05-09T19:24:23.725746+10:00", "external_links": [], "uuid": "329d37e4-3528-4e9f-bb96-64fa8b55160d", "