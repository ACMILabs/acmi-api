{"count": 28684, "next": "https://api.acmi.net.au/creators/?page=959", "previous": "https://api.acmi.net.au/creators/?page=957", "results": [{"id": 75999, "name": "Julia Reichert", "roles_in_work": [{"id": 897456, "title": "Union maids", "work_id": 77537, "role": "co-director", "role_id": 959, "is_primary": true}, {"id": 2267062, "title": "Seeing red: stories of American communists", "work_id": 78482, "role": "co-producers/directors", "role_id": 628, "is_primary": true}], "also_known_as": "", "date_of_birth": "1946-06-16", "date_of_death": "2022-12-01", "genders": [{"id": 5, "name": "Female", "slug": "female"}], "languages": [], "places_of_operation": [{"id": 1, "name": "United States of America", "slug": "united-states-of-america"}], "biography": "Julia Bell Reichert (June 16, 1946 – December 1, 2022) was an American Academy Award-winning documentary filmmaker, activist, and feminist. She was a co-founder of New Day Films. Reichert's filmmaking career spanned over 50 years as a director and producer of documentaries.\nReichert was a four-time Academy Award-nominated director, for Union Maids (1977), Seeing Red: Stories of American Communists (1984), The Last Truck: Closing of a GM Plant (2010) and American Factory (2020, for which she won an Oscar).  \nShe was a two-time winner of the Primetime Emmy, a two-time nominee of the Peabody Award, and director of two films on the National Film Registry.  \nReichert was the recipient of the award for Distinguished Service to Labor and Working-Class History from the Labor and Working-Class History Association (LAWCHA). She was professor emeritus in the Department of Theatre, Dance and Motion Pictures at Wright State University.\nReichert was honored with lifetime achievement awards from the International Documentary Association, the Full Frame Documentary Film Festival, and the Hot Docs Film Festival.  She is a recipient of the Chicken & Egg Pictures 'Breakthrough Prize.' A traveling retrospective of her work was curated by the Wexner Center for the Arts, and was launched at the Museum of Modern Art in May 2019, before traveling to other US cities.", "biography_author": "Wikidata", "date_of_biography": "2023-08-01T15:45:06.326054+10:00", "external_links": [{"id": 2922, "uri": "https://en.wikipedia.org/wiki/Julia_Reichert"}], "uuid": "c7f79fa2-f175-49e2-ab4b-28081ce0bc1f", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "22844", "external_references": [{"id": 26371, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q1711898"}, {"id": 29700, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "73157523317127031805"}], "date_modified": "2023-09-05T21:54:49.162249+10:00"}, {"id": 75998, "name": "Miles Mogulescu", "roles_in_work": [{"id": 897455, "title": "Union maids", "work_id": 77537, "role": "co-director", "role_id": 959, "is_primary": true}], "also_known_as": "", "date_of_birth": "1947-01-01", "date_of_death": null, "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": null, "external_links": [], "uuid": "1442c5d7-1423-4fce-a578-547963a4f300", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": null, "external_references": [{"id": 11720, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q22102048"}, {"id": 11721, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "66106667"}, {"id": 11722, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "no99049647"}, {"id": 11723, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-no99049647"}], "date_modified": "2023-09-05T23:15:58.519119+10:00"}, {"id": 75997, "name": "Luciano Martinengo", "roles_in_work": [{"id": 2408456, "title": "George Melies cinema magician", "work_id": 77535, "role": "co-director", "role_id": 959, "is_primary": true}], "also_known_as": "", "date_of_birth"