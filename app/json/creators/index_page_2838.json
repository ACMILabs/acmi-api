 {"name": "Vernon", "slug": "vernon"}, "source_identifier": "111125", "external_references": [], "date_modified": "2025-03-12T22:59:36.013534+11:00"}, {"id": 7298, "name": "Sally Pryor", "roles_in_work": [{"id": 2648271, "title": "Dream house", "work_id": 78712, "role": "director", "role_id": 938, "is_primary": true}, {"id": 2619203, "title": "Postcard from Tunis", "work_id": 108296, "role": "director", "role_id": 938, "is_primary": true}, {"id": 2619199, "title": "Postcard from Tunis", "work_id": 108296, "role": "creator", "role_id": 968, "is_primary": true}, {"id": 2619201, "title": "Postcard from Tunis", "work_id": 108296, "role": "programmer", "role_id": 483, "is_primary": false}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "Sally Pryor is an Australian artist/programmer/animator and independent multimedia developer with an eclectic background including biochemestry and 3D computer animation. Her current works-in-progress,\nAS WE MAY WRITE and WRITING IN BITS explore writing and the human-computer interface.\n\nSally began working with computers in 1979. In' 83 she retrained as one of Australia's earliest 3D computer animators, making her 3D film DREAM HOUSE, the first Australian work selected for the prestigious SIGGRAPH screenings in the USA ('84). After working as a commercial computer animator in the USA and Australia, Sally switched to desktop computers and an exploration of art, technology, subjectivity and gender. Sally was actively involved in the early days of the Australian Art and Technology scene, widely exhibiting, lecturing and writing about these themes.\n\nSally's landmark paper THINKING OF ONESLEF AS A COMPUTER was published in Leonardo in '91. Her video COMPUTERS ARE FUN (or BARBIE MEETS THE COMPUTER) was later ('94) selected for An Eccentric Orbit, a major survey of video art in Australia, which premiered at the Museum of Modern Art, NY.\n\nIn late '91 Sally left Australia for Tunis, North Africa. Her experiences, which included marrying a Tunisian man, led several years later to the production of POSTCARD FROM TUNIS.\n\nIn '97, Sally was awarded the inaugural Elektra Award for a woman with outstanding achievements in the area of new technology, by WIFT (Women in Film and Television) Australia.\n\nIn '98 Sally left her lecturing position at the University of Technology in order to concentrate on artistic productions and her doctoral studies at the University of Western Sydney. In 1999 she was awarded a two year artistic fellowship from the New Media Fund of the Australia Council and moved from Bondi to Ballarat, in rural Victoria.", "biography_author": null, "date_of_biography": "2025-03-05T13:41:44.417169+11:00", "external_links": [], "uuid": "aa788720-a700-47e6-b39a-89046abf7148", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "110858", "external_references": [{"id": 40588, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q121337612"}], "date_modified": "2025-03-05T13:41:44.417383+11:00"}, {"id": 7292, "name": "Aaron Burton", "roles_in_work": [{"id": 881444, "title": "The Burglar cometh", "work_id": 92820, "role": "director", "role_id": 938, "is_primary": true}], "also_known_as": "", "date_of_birth": null, "date_of_death": null, "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": null, "external_links": [], "uuid": "ddce1145-cad5-45e8-9ddb-a6afd62c2829", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "111223", "external_references": [{"id": 35159, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q120700021"}], "date_modified": "2023-09-13T12:27:58.322800+10:00"}, {"id": 7265, "name": "Sharon Connolly", "roles_in_work": [{"id": 775904, "title": "It's a business doing pleasure", "work_id": 81552, "role": "director", "role_id": 938, "is_primary": true},