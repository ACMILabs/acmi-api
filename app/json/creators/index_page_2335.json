21357953"}], "date_modified": "2023-09-05T18:11:17.494863+10:00"}, {"id": 16081, "name": "Department of Army", "roles_in_work": [{"id": 856269, "title": "On parade. No. 10. The Army was ready", "work_id": 71092, "role": "production company", "role_id": 941, "is_primary": true}, {"id": 875140, "title": "Royal parade", "work_id": 89333, "role": "production company", "role_id": 941, "is_primary": true}, {"id": 2645348, "title": "Jungle road", "work_id": 69321, "role": "production company", "role_id": 941, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": "2023-08-11T19:03:34.145472+10:00", "external_links": [], "uuid": "d50c7323-0772-4fe0-be27-b0730a470c64", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "7413", "external_references": [], "date_modified": "2025-03-05T12:37:21.086139+11:00"}, {"id": 16080, "name": "Tom Gurr", "roles_in_work": [{"id": 853975, "title": "Jungle patrol", "work_id": 69320, "role": "director", "role_id": 938, "is_primary": true}, {"id": 2391959, "title": "One man's war", "work_id": 71138, "role": "director", "role_id": 938, "is_primary": true}], "also_known_as": "", "date_of_birth": null, "date_of_death": "1995-08-09", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [{"id": 1, "name": "English", "slug": "english"}], "places_of_operation": [{"id": 3, "name": "Australia", "slug": "australia"}], "biography": "Thomas Johnson Gurr (1904, Dunedin, New Zealand – 9 August 1995) was an Australian journalist and documentary filmmaker. He worked for Cinesound Productions writing commentary for newsreels until 1933 when he left to join Associated Newspapers. By 1938 he was editor in chief at the Sunday Telegraph and he later edited the Sydney Sun.\nDuring the war, Tom served as a War Correspondent with Associated Newspapers.  He became a member of the Australian Commonwealth Government Editors' Delegation and travelled to Indonesia, Malaysia, and Korea, and watched the D-Day invasion from above, flying over the scene. Tom was decorated with seven service medals for his work as a war correspondent, and marched in every Anzac Day ceremony in Sydney, Australia, until the age of 90.\nDuring World War II he also wrote and directed the classic action documentary film Jungle Patrol (1944), and later made a similar film during the Korean War, One Man's War (1952).His sister, Nancy Gurr (Thompson), was also a pioneer of the Australian film industry.  His brother, Rodney Gurr, worked for MGM in the US before returning to Australia.  Their father \"Thomas Stuart Gurr\" was a novelist and writer.", "biography_author": "Wikidata", "date_of_biography": "2023-08-01T17:19:36.125614+10:00", "external_links": [{"id": 5277, "uri": "https://en.wikipedia.org/wiki/Tom_Gurr"}], "uuid": "7feee718-fdb9-4708-b35d-8e8f8b9015fc", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "29837", "external_references": [{"id": 25723, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q7816038"}], "date_modified": "2023-09-13T12:33:02.589544+10:00"}]}