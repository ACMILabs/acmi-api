{"count": 28684, "next": "https://api.acmi.net.au/creators/?page=1525", "previous": "https://api.acmi.net.au/creators/?page=1523", "results": [{"id": 33025, "name": "Rupert Wainwright", "roles_in_work": [{"id": 2311429, "title": "Stigmata", "work_id": 91646, "role": "director", "role_id": 938, "is_primary": true}, {"id": 1978715, "title": "Blank check", "work_id": 95457, "role": "director", "role_id": 938, "is_primary": true}], "also_known_as": "", "date_of_birth": "1961-11-30", "date_of_death": "", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [{"id": 1, "name": "English", "slug": "english"}], "places_of_operation": [{"id": 10, "name": "United Kingdom", "slug": "united-kingdom"}], "biography": "Rupert Wainwright is an English film and television director, with credits including Blank Check (1994), The Sadness of Sex (1995) and Stigmata (1999). He is also a music video producer and multiple award-winner.\nBritish-born, Wainwright was one of the youngest directors accepted in the Discovery Program sponsored by Columbia Pictures. He established a reputation for making award-winning television advertisements (including Reebok) and music videos (most notably M.C. Hammer). \nOriginally an actor, appearing in Another Country (1984) and Dreamchild (1985), Wainright later directed the ABC film Dillinger (1991) starring Mark Harmon. In 2005, he directed the supernatural horror film The Fog.", "biography_author": "Wikidata", "date_of_biography": "2023-08-01T16:56:57.839775+10:00", "external_links": [{"id": 5090, "uri": "https://en.wikipedia.org/wiki/Rupert_Wainwright"}], "uuid": "9f12d07e-c208-4e9a-9b6a-3a029dc773fb", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "28343", "external_references": [{"id": 26005, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q971738"}, {"id": 31340, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "69138312"}, {"id": 31341, "source": {"name": "LOC Auth", "sl