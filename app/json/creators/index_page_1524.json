n Ferrer (August 25, 1917 – June 2, 2008) was an American actor, director, and producer of stage, film, and television. He achieved prominence on Broadway before scoring notable film hits with Scaramouche, Lili and Knights of the Round Table. He starred opposite his wife, actress Audrey Hepburn, in War and Peace, and produced her film Wait Until Dark. He also acted extensively in European films, and appeared in several cult hits, including The Antichrist (1974), The Suspicious Death of a Minor (1975), The Black Corsair (1976), and Nightmare City (1980).", "biography_author": "Wikidata", "date_of_biography": "2022-05-19T12:26:59.736585+10:00", "external_links": [{"id": 2689, "uri": "https://en.wikipedia.org/wiki/Mel_Ferrer"}], "uuid": "82ca5c0d-b1ac-4810-8d4c-ebf981d88c0b", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "24912", "external_references": [{"id": 11476, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q333475"}, {"id": 11477, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "114941496"}, {"id": 11478, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "n85048237"}, {"id": 11479, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-n85048237"}], "date_modified": "2023-09-13T12:31:22.125236+10:00"}, {"id": 33003, "name": "Richard Rubinstein", "roles_in_work": [{"id": 2179935, "title": "Day of the dead (D)", "work_id": 91595, "role": "producer", "role_id": 1089, "is_primary": true}, {"id": 2179194, "title": "Dawn of the dead (Uncut version) [DVD] (D)", "work_id": 94365, "role": "producer", "role_id": 1089, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": "2023-05-09T14:51:07.221377+10:00", "external_links": [], "uuid": "487c017e-0d33-4e69-b927-038dd805b601", "source": {"name": "Vernon", "slug