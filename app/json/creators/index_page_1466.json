10:00"}, {"id": 35000, "name": "Feliks Falk", "roles_in_work": [{"id": 1997381, "title": "Top dog = Wodzirej [NTSC]", "work_id": 93292, "role": "director", "role_id": 938, "is_primary": true}], "also_known_as": "", "date_of_birth": "1941-02-25", "date_of_death": null, "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [{"id": 24, "name": "Polish", "slug": "polish"}], "places_of_operation": [{"id": 44, "name": "Poland", "slug": "poland"}], "biography": "Feliks Falk ps. Robert F. Lane, Edward Neyman (born 25 February 1941) is a Polish film and theater director as well as writer of film scripts, stage plays, television plays, and radio shows. A 1966 graduate of Warsaw's Academy of Fine Arts, he also is a painter and graphic artist. Falk is one of creators of the 1970s wave of Polish cinematography, called Cinema of Moral Anxiety. His most famous films include Wodzirej (Top Dog) (1977) and Samowolka (AWOL) (1993). Falk has won a number of major filmmaking awards. His 1987 film Hero of the Year was entered into the 15th Moscow International Film Festival where it won the FIPRESCI Prize and a Special Prize.", "biography_author": "Wikidata", "date_of_biography": "2023-08-01T14:49:11.758071+10:00", "external_links": [{"id": 3966, "uri": "https://en.wikipedia.org/wiki/Feliks_Falk"}], "uuid": "894ce827-84f8-42c5-85b5-089555a7d4dd", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "18976", "external_references": [{"id": 26769, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q325626"}, {"id": 28393, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "84977610"}, {"id": 28394, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "no98088618"}, {"id": 28395, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-no98088618"}], "date_modified": "2023-09-13T12:29:21.828133+10:00"}, {"id": 34997, "name": "Andrzej Munk", "roles_in_work": [{"id": 1997379, "title": "Bad luck = Zezowate szczescie [NTSC]", "work_id": 93290, "role": "director", "role_id": 938, "is_primary": true}], "also_known_as": "", "date_of_birth": "1921-10-16", "date_of_death": "1961-09-20", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [{"id": 24, "name": "Polish", "slug": "polish"}], "places_of_operation": [{"id": 44, "name": "Poland", "slug": "poland"}], "biography": "Andrzej Munk (16 October 1921 – 20 September 1961) was a Polish film director, screen writer and documentalist. He was one of the most influential artists of the post-Stalinist period in the People's Republic of Poland. His feature films Man on the Tracks (Człowiek na torze, 1956), Eroica (Heroism, 1958), Bad Luck (Zezowate szczęście, 1960), and Passenger (Pasażerka 1963), are considered classics of the Polish Film School developed in mid-1950s. He died as a result of a car crash in Kompina in a head-on collision with a truck.\n\n", "biography_author": "Wikidata", "date_of_biography": "2022-05-19T10:49:54.156895+10:00", "external_links": [{"id": 1653, "uri": "https://en.wikipedia.org/wiki/Andrzej_Munk"}], "uuid": "6232f26f-6e69-497d-bc11-15e1f1598e32", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "15237", "external_references": [{"id": 7213, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q515331"}, {"id": 7214, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "2725279"}, {"id": 7215, "source": {"name": "LOC Auth", "slug": "loc-auth"}, "source_identifier": "n84204847"}, {"id": 7216, "source": {"name": "WorldCat", "slug": "worldcat"}, "source_identifier": "lccn-n84204847"}], "date_modified": "2023-09-13T12:28:12.888789+10:00"}]}