2649996, "title": "Babar. School days; King Tuttle's vote", "work_id": 82571, "role": "co-producer", "role_id": 915, "is_primary": true}, {"id": 916742, "title": "Little Bear: hide and seek", "work_id": 94918, "role": "co-producer", "role_id": 915, "is_primary": true}, {"id": 1847666, "title": "Little Bear: exploring", "work_id": 87352, "role": "co-producer", "role_id": 915, "is_primary": true}, {"id": 2066703, "title": "A Cosmic christmas", "work_id": 81820, "role": "co-producer", "role_id": 915, "is_primary": true}, {"id": 1846728, "title": "Inspector Gadget. Travel trouble", "work_id": 83343, "role": "co-producer", "role_id": 915, "is_primary": true}, {"id": 1846732, "title": "Inspector Gadget solves his case", "work_id": 83344, "role": "co-producer", "role_id": 915, "is_primary": true}, {"id": 2105835, "title": "Babar. Babar's Triumph", "work_id": 81362, "role": "co-producer", "role_id": 915, "is_primary": true}, {"id": 2345043, "title": "The Devil and Daniel mouse", "work_id": 77624, "role": "co-producer", "role_id": 915, "is_primary": true}, {"id": 1846741, "title": "Inspector Gadget monster madness", "work_id": 83346, "role": "co-producer", "role_id": 915, "is_primary": true}, {"id": 2105891, "title": "Babar. Elephant's best friend; The Show must go on", "work_id": 82721, "role": "co-producer", "role_id": 915, "is_primary": true}, {"id": 2218816, "title": "Energy management for the future", "work_id": 87740, "role": "producer", "role_id": 1089, "is_primary": true}], "also_known_as": "", "date_of_birth": null, "date_of_death": "", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [], "places_of_operation": [{"id": 36, "name": "Canada", "slug": "canada"}], "biography": "Patrick Loubert (born 1947 in Toronto, Ontario) is one of the founders of the Canadian animation studio, Nelvana Limited, along with Clive A. Smith and Michael Hirsh. He has produced, and executive-produced, much of the company's most memorable fare.\n\nAt the beginning of his career, Loubert published The Great Canadian Comic Books, a 1971 book focusing on the early days of local comic lore, with partner Hirsh. With Don Haig, he scripted and directed 125 Rooms of Comfort, another live-action project, in 1974. He also produced the first season of Inspector Gadget for DIC Entertainment with show's creator Jean Chalopin (The first season was animated and co-produced by Nelvana), Gargoyles: The Goliath Chronicles for Disney and Buena Vista, the adventure game Toonstruck and the American thriller film Malice (starring Alec Baldwin, Nicole Kidman and Bill Pullman) and worked as a storyboard artist and story writer for Nelvana's first feature-length film Rock and Rule and executive story editor for the third Care Bears feature film The Care Bears Adventure in Wonderland. He also created the live-action TV series for Nelvana The Edison Twins and T. and T. (starring Mr. T) with Michael Hirsh and wrote scripts for the company's first two animated specials A Cosmic Christmas and The Devil and Daniel Mouse as well as writing the scripts for Babar: The Movie.\n\nLoubert and his colleagues won an Emmy Award in 1990 (in the category Outstanding Animated Program) for the children's television series Beetlejuice. Source: Wikidata; 01/08/2023", "biography_author": null, "date_of_biography": "2025-03-05T14:08:20.136791+11:00", "external_links": [{"id": 4823, "uri": "https://en.wikipedia.org/wiki/Patrick_Loubert"}], "uuid": "865045c7-9f18-457e-8cba-b1043fb7309a", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "26136", "external_references": [{"id": 25388, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q10346114"}, {"id": 30645, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "311675055"}], "date_modified": "2025-03-05T14:08:20.137116+11:00"}, {"id": 76026, "name": "Douglas Kiefer", "roles_in_work": [{"id": 910240, "title": "Oceans of science", "work_id": 90845, "role": "co-director", "role_id": 959, "is_primary": true}, {"id": 2757498, "title": "Small is beautiful", "work_id": 77621, "role": "co-producers/directors", "role_id": 628, "is_primary": true}, {"id": 2784569, "title": "Keeping the old game alive", "work_id": 99279, "role": "producer/director", "role_id": 31, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": "2023-05-09T18:40:56.125024+10:00", "external_links": [], "uuid": "2c506c31-1666-416c-9310-ddb34acef978", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "18367", "external_references": [{"id": 40522, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q121036817"}], "date_modified": "2025-03-14T19:21:15.505899+11:00"}, {"id": 76025, "name": "Stefan Wodoslawsky", "roles_in_work": [{"id": 2123603, "title": "Bravery in the field", "work_id": 77615, "role": "co-producer", "role_id": 915, "is_primary": true}], "also_known_as": "", "date_of_birth": "1952-01-01", "date_of_death": "", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [], "places_of_operation": [], "biography": "Stefan Wodoslawsky (born 1951) is a Canadian film producer and actor. Associated in his early career with the National Film Board of Canada, he is most noted as coproducer with Roman Kroitor of the 1979 film Bravery in the Field, which was an Academy Award nominee for Best Live Action Short Film at the 52nd Academy Awards and won the Genie Award for Best TV Drama Under 30 Minutes at the 1st Genie Awards.Wodoslawsky was born in Sydney, Nova Scotia. In the 1980s, he also had a number of acting roles, beginning with Giles Walker's mockumentary trilogy The Masculine Mystique, 90 Days and The Last Straw. He also starred in the 1988 drama film Something About Love, on which he was also a coproducer and cowriter. In the same era, he was codirector with Tony Ianzelo of Give Me Your Answer True, a documentary film profiling actor Donald Sutherland.After leaving the National Film Board he joined the commercial production firm Allegro Films, working primarily on dramatic thriller and television films.", "biography_author": "Wikidata", "date_of_biography": "2023-09-06T01:27:32.060639+10:00", "external_links": [{"id": 6191, "uri": "https://en.wikipedia.org/wiki/Stefan_Wodoslawsky"}], "uuid": "d5189477-1053-432d-abb5-167cfedb26ea", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "28996", "external_references": [{"id": 36012, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q22102081"}, {"id": 55857, "source": {"name": "VIAF", "slug": "viaf"}, "source_identifier": "87023982"}], "date_modified": "2023-09-06T01:27:32.081705+10:00"}, {"id": 76024, "name": "Janice H Brown", "roles_in_work": [{"id": 2358198, "title": "The Lady from Grey County", "work_id": 88669, "role": "director", "role_id": 938, "is_primary": true}, {"id": 2327360, "title": "The Agony of Jimmy Quinlan", "work_id": 77613, "role": "co-director", "role_id": 959, "is_primary": true}], "also_known_as": "", "date_of_birth": "", "date_of_death": "", "genders": [], "languages": [], "places_of_operation": [], "biography": "", "biography_author": null, "date_of_biography": "2023-05-09T20:07:16.048872+10:00", "external_links": [], "uuid": "0a7cf862-b7ed-4a23-8c78-705ac54382c5", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "21455", "external_references": [{"id": 41149, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q121091326"}], "date_modified": "2023-09-05T21:08:51.250639+10:00"}, {"id": 76023, "name": "Robert Duncan", "roles_in_work": [{"id": 2281007, "title": "View from the typewriter", "work_id": 93780, "role": "director", "role_id": 938, "is_primary": true}, {"id": 1427660, "title": "John McCrae's war: in Flanders Fields", "work_id": 87358, "role": "director", "role_id": 938, "i