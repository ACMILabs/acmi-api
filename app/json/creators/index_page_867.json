ony Thomas", "roles_in_work": [{"id": 2180974, "title": "Dead poets society [DVD]", "work_id": 92511, "role": "co-producer", "role_id": 915, "is_primary": true}, {"id": 1993890, "title": "Moving in = Firstborn", "work_id": 89581, "role": "co-producer", "role_id": 915, "is_primary": true}, {"id": 2181746, "title": "Dead Poets Society (Captioned)", "work_id": 81467, "role": "co-producer", "role_id": 915, "is_primary": true}, {"id": 2051524, "title": "[Dead poets society : publicity kit]", "work_id": 118380, "role": "producer", "role_id": 1089, "is_primary": true}], "also_known_as": "", "date_of_birth": "1948-12-07", "date_of_death": "", "genders": [{"id": 9, "name": "Male", "slug": "male"}], "languages": [{"id": 1, "name": "English", "slug": "english"}], "places_of_operation": [{"id": 1, "name": "United States of America", "slug": "united-states-of-america"}], "biography": "Charles Anthony Thomas (né Jacobs; born December 7, 1948) is an Academy Award nominated American television and film producer. He was a producer for the feature film Dead Poets Society for which he was nominated for the Academy Award for Best Picture in 1989, and Insomnia, among other films.He is also the producer of many successful television series from the 1970s into the 1990s such as Golden Girls for which he won the Primetime Emmy Award for Outstanding Comedy Series twice and won three consecutive Golden Globe Awards for Best Television Series – Musical or Comedy. Thomas was the producer of Blossom and many other TV series. He is the co-founder of Witt/Thomas Productions.", "biography_author": "Wikidata", "date_of_biography": "2023-08-01T17:21:32.533355+10:00", "external_links": [{"id": 5296, "uri": "https://en.wikipedia.org/wiki/Tony_Thomas_(producer)"}], "uuid": "110d6be9-3f79-49b4-9bbb-14128a447bda", "source": {"name": "Vernon", "slug": "vernon"}, "source_identifier": "29908", "external_references": [{"id": 26059, "source": {"name": "Wikidata", "slug": "wikidata"}, "source_identifier": "Q35